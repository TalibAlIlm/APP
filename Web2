    <div class="li"><div class="ld" style="background:#fff59d"></div>Tafsir</div>
    <div class="li"><div class="ld" style="background:#c5e1a5"></div>Fara&#x02BE;id</div>
    <div class="li"><div class="ld" style="background:#ffe082"></div>Balagha</div>
