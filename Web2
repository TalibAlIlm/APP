function resetZoom(){svg.transition().duration(420).ease(d3.easeCubicOut).call(zoom.transform,d3.zoomIdentity.translate(W*.07,H/2).scale(.92));}
function expandAll(){root.descendants().forEach(d=>{if(d._children){d.children=d._children;d._children=null;}});clearFocus();update(root);}
function collapseToLevels(){root.descendants().forEach(d=>{if(d.depth>=2&&d.children){d._children=d.children;d.children=null;}});clearFocus();update(root);}

