const searchIndex=[];
(function buildIdx(node,ln,sn){
  if(node.type==="book"){searchIndex.push({...node,levelName:ln,subjName:sn});return;}
  (node.children||[]).forEach(c=>buildIdx(c,node.type==="level"?node.name:ln,node.type==="subject"?node.name:sn));
})(TREE,"","");

