          { name: "al-ʿIlal al-Dāraquṭnī", arabic: "العلل للدارقطني", author: "al-Dāraquṭnī", size: "Encyclopedic", type: "book", color: "#b39ddb" },
        ]},
        { name: "Uṣūl al-Fiqh", type: "subject", color: "#ce93d8", children: [
          { name: "Rawḍat al-Nāẓir", arabic: "روضة الناظر", author: "Ibn Qudāma", size: "Grad level", type: "book", color: "#ce93d8" },
        ]},
        { name: "Tafsīr", type: "subject", color: "#fff59d", children: [
          { name: "Tafsīr Ibn Kathīr (Full)", arabic: "تفسير ابن كثير الكامل", author: "Ibn Kathīr", size: "4 volumes", type: "book", color: "#fff59d" },
          { name: "Maʿālim al-Tanzīl (Baghawī)", arabic: "معالم التنزيل", author: "al-Baghawī", size: "4 volumes", type: "book", color: "#fff59d" },
        ]},
        { name: "Naḥw — Mastery", type: "subject", color: "#a5d6a7", children: [
          { name: "Sharḥ Ibn ʿAqīl", arabic: "شرح ابن عقيل على الألفية", author: "Ibn ʿAqīl", size: "Commentary", type: "book", color: "#a5d6a7" },
          { name: "al-Kāfiya fī ʿIlm al-Naḥw", arabic: "الكافية في علم النحو", author: "Ibn al-Ḥājib", size: "Advanced", type: "book", color: "#a5d6a7" },
        ]},
        { name: "History", type: "subject", color: "#ffab91", children: [
          { name: "al-Bidāya wa al-Nihāya", arabic: "البداية والنهاية", author: "Ibn Kathīr", size: "14 volumes", type: "book", color: "#ffab91" },
          { name: "Siyar Aʿlām al-Nubalāʾ", arabic: "سير أعلام النبلاء", author: "al-Dhahabī", size: "25 volumes", type: "book", color: "#ffab91" },
        ]},
        { name: "Tazkiyya", type: "subject", color: "#bcaaa4", children: [
          { name: "al-Wābil al-Ṣayyib", arabic: "الوابل الصيب", author: "Ibn al-Qayyim", size: "Advanced", type: "book", color: "#bcaaa4" },
        ]},
      ]
    }
  ]
};

// ═══════════ LEVEL COLORS ═══════════
const levelColors = {
  1: "#4caf50",
  2: "#42a5f5",
  3: "#ce93d8",
  4: "#ff8a65",
  5: "#c9a84c"
};

// ═══════════ D3 TREE SETUP ═══════════
const svg = d3.select("#canvas");
const width = window.innerWidth;
const height = window.innerHeight;

const g = svg.append("g").attr("transform", `translate(${width * 0.06}, ${height / 2})`);

// Zoom behavior
const zoom = d3.zoom()
  .scaleExtent([0.15, 3])
  .on("zoom", (event) => {
    g.attr("transform", event.transform);
  });

svg.call(zoom).call(zoom.transform, d3.zoomIdentity.translate(width * 0.06, height / 2));

// Tree layout — horizontal (left to right)
const tree = d3.tree().nodeSize([22, 280]);

let root = d3.hierarchy(treeData);

// Collapse all except first two levels initially
root.descendants().forEach(d => {
  if (d.depth >= 2) {
    d._children = d.children;
    d.children = null;
  }
});

function getNodeColor(d) {
  if (d.data.type === "root") return "#c9a84c";
  if (d.data.type === "level") return levelColors[d.data.level] || "#c9a84c";
  if (d.data.type === "subject") return d.data.color || "#888";
  if (d.data.type === "book") return d.data.color || "#888";
  return "#888";
}

function getNodeRadius(d) {
  if (d.data.type === "root") return 14;
  if (d.data.type === "level") return 10;
  if (d.data.type === "subject") return 7;
  return 5;
}

function getLinkColor(d) {
  const target = d.target;
  if (target.data.type === "level") return levelColors[target.data.level] || "#444";
  if (target.data.type === "subject") return target.data.color || "#444";
  if (target.data.type === "book") return target.data.color || "#444";
  return "#444";
}

// Text labels — trim to fit
function getLabel(d) {
  const name = d.data.name;
  if (d.data.type === "root") return "Ṭālib al-ʿIlm";
  if (d.data.type === "level") return d.data.name + " · " + (d.data.subtitle || "");
  if (d.data.type === "subject") {
    const hasChildren = (d.children || d._children);
    const count = hasChildren ? ` [${(d.children || d._children).length}]` : "";
    return name + count;
  }
  // book
  const short = name.length > 32 ? name.substring(0, 30) + "…" : name;
  return (d.data.mem ? "★ " : "") + short;
}

let nodeId = 0;

function update(source) {
  const treeData = tree(root);
  const nodes = treeData.descendants();
  const links = treeData.links();

  // ── LINKS ──
  const link = g.selectAll(".link")
    .data(links, d => d.target.id);

  const linkEnter = link.enter().append("path")
    .attr("class", "link")
    .attr("d", d => {
      const o = {x: source.x0 || 0, y: source.y0 || 0};
      return diagonal({source: o, target: o});
    })
    .attr("stroke", d => getLinkColor(d))
    .attr("opacity", 0);

  link.merge(linkEnter)
    .transition().duration(350)
    .attr("d", diagonal)
    .attr("stroke", d => getLinkColor(d))
    .attr("opacity", 0.3);

  link.exit().transition().duration(350)
    .attr("d", d => {
      const o = {x: source.x, y: source.y};
      return diagonal({source: o, target: o});
    })
    .attr("opacity", 0)
    .remove();

  // ── NODES ──
  const node = g.selectAll(".node")
    .data(nodes, d => d.id || (d.id = ++nodeId));

  const nodeEnter = node.enter().append("g")
    .attr("class", d => "node node-" + d.data.type)
    .attr("transform", d => `translate(${source.y0 || 0},${source.x0 || 0})`)
    .attr("opacity", 0)
    .on("click", (event, d) => {
      event.stopPropagation();
      if (d.data.type === "book") return;
      if (d.children) {
        d._children = d.children;
        d.children = null;
      } else {
        d.children = d._children;
        d._children = null;
      }
      update(d);
    })
    .on("mouseover", (event, d) => {
      if (d.data.type === "root" || d.data.type === "level") return;
      const tt = document.getElementById("tooltip");
      let html = "";
      if (d.data.type === "subject") {
        html = `<div class="tt-title">${d.data.name}</div>`;
        const count = (d.children || d._children || []).length;
        html += `<div class="tt-meta">${count} text${count !== 1 ? "s" : ""} in this subject</div>`;
      } else {
        html = `<div class="tt-title">${d.data.name}</div>`;
        if (d.data.arabic) html += `<div class="tt-arabic">${d.data.arabic}</div>`;
        if (d.data.author) html += `<div class="tt-author">${d.data.author}</div>`;
        if (d.data.size) html += `<div class="tt-meta">Size: ${d.data.size}</div>`;
        if (d.data.mem) html += `<div class="tt-mem">★ Memorize</div>`;
      }
      tt.innerHTML = html;
      tt.style.opacity = "1";
      tt.style.left = (event.clientX + 14) + "px";
      tt.style.top = (event.clientY - 10) + "px";
    })
    .on("mousemove", (event) => {
      const tt = document.getElementById("tooltip");
      tt.style.left = (event.clientX + 14) + "px";
      tt.style.top = (event.clientY - 10) + "px";
    })
    .on("mouseout", () => {
      document.getElementById("tooltip").style.opacity = "0";
    });

  nodeEnter.append("circle")
    .attr("r", d => getNodeRadius(d))
    .attr("fill", d => {
      const c = getNodeColor(d);
      if (d.data.type === "book") return c + "22";
      if (d.data.type === "subject") return c + "33";
      return c + "44";
    })
    .attr("stroke", d => getNodeColor(d))
    .attr("stroke-width", d => d.data.type === "root" ? 2 : 1.5);

  // Collapse indicator
  nodeEnter.append("circle")
    .attr("class", "collapse-indicator")
    .attr("r", 2.5)
    .attr("fill", d => getNodeColor(d))
    .attr("opacity", d => (d._children || d.children) && d.data.type !== "book" ? 0.7 : 0);

  nodeEnter.append("text")
    .attr("dy", "0.31em")
    .attr("x", d => {
      const r = getNodeRadius(d);
      return (d.children || d._children) ? -(r + 5) : (r + 5);
    })
    .attr("text-anchor", d => (d.children || d._children) ? "end" : "start")
    .attr("font-size", d => {
      if (d.data.type === "root") return "13px";
      if (d.data.type === "level") return "11px";
      if (d.data.type === "subject") return "10px";
      return "9px";
    })
    .attr("fill", d => {
      if (d.data.type === "root") return "#c9a84c";
      if (d.data.type === "level") return levelColors[d.data.level] || "#c9a84c";
      if (d.data.type === "subject") return (d.data.color || "#888") + "cc";
      return d.data.mem ? "#c9a84c" : (d.data.color || "#888") + "99";
    })
    .attr("letter-spacing", d => d.data.type === "level" ? "0.1em" : "0.03em")
    .text(d => getLabel(d));

  // Merge and transition
  node.merge(nodeEnter)
    .transition().duration(350)
    .attr("transform", d => `translate(${d.y},${d.x})`)
    .attr("opacity", 1);

  // Update collapse indicators
  node.merge(nodeEnter).select(".collapse-indicator")
    .attr("opacity", d => (d._children) && d.data.type !== "book" ? 0.7 : 0);

  // Update text anchors on expand/collapse
  node.merge(nodeEnter).select("text")
    .attr("x", d => {
      const r = getNodeRadius(d);
      return (d.children || d._children) ? -(r + 5) : (r + 5);
    })
    .attr("text-anchor", d => (d.children || d._children) ? "end" : "start");

  node.exit()
    .transition().duration(350)
    .attr("transform", d => `translate(${source.y},${source.x})`)
    .attr("opacity", 0)
    .remove();

  nodes.forEach(d => {
    d.x0 = d.x;
    d.y0 = d.y;
  });
}

// Bezier diagonal for horizontal tree
function diagonal(d) {
  return `M ${d.source.y} ${d.source.x}
          C ${(d.source.y + d.target.y) / 2} ${d.source.x},
            ${(d.source.y + d.target.y) / 2} ${d.target.x},
            ${d.target.y} ${d.target.x}`;
}

root.x0 = 0;
root.y0 = 0;
update(root);

// ═══════════ CONTROLS ═══════════
function resetZoom() {
  svg.transition().duration(400).call(
    zoom.transform,
    d3.zoomIdentity.translate(width * 0.06, height / 2).scale(1)
  );
}

function expandAll() {
  root.descendants().forEach(d => {
    if (d._children) {
      d.children = d._children;
      d._children = null;
    }
  });
  update(root);
}

function collapseAll() {
  root.descendants().forEach(d => {
    if (d.depth >= 2 && d.children) {
      d._children = d.children;
      d.children = null;
    }
  });
  update(root);
}

// Resize
window.addEventListener("resize", () => {
  svg.attr("width", window.innerWidth).attr("height", window.innerHeight);
});
</script>
</body>
</html>
