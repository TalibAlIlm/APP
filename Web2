    el.onclick=()=>{
      const on=activeFilters.has(cat.c);
      on?activeFilters.delete(cat.c):activeFilters.add(cat.c);
      el.classList.toggle("active",!on);
      el.style.background=on?"":cat.c;
      el.style.color=on?"":"#0c0904";
      clearFocus();update(root);
    };
    con.appendChild(el);
  });
})();

/* ════════════════════════════════════════════════════════
   TREE CONTROLS
════════════════════════════════════════════════════════ */
function resetZoom(){
  svg.transition().duration(400).ease(d3.easeCubicInOut)
    .call(zoom.transform,d3.zoomIdentity.translate(W*.07,H/2).scale(.92));
}
function expandAll(){
  root.descendants().forEach(d=>{if(d._children){d.children=d._children;d._children=null;}});
  clearFocus();update(root);
}
function collapseToLevels(){
  root.descendants().forEach(d=>{if(d.depth>=2&&d.children){d._children=d.children;d.children=null;}});
  clearFocus();update(root);
}

/* ════════════════════════════════════════════════════════
   VIEW TOGGLE
════════════════════════════════════════════════════════ */
function setView(v){
  document.getElementById("btn-tree").classList.toggle("active",v==="tree");
  document.getElementById("btn-list").classList.toggle("active",v==="list");
  document.getElementById("canvas").style.display=v==="tree"?"block":"none";
  document.getElementById("listview").classList.toggle("show",v==="list");
  document.getElementById("hint").style.display=v==="tree"?"block":"none";
  document.getElementById("controls").style.display=v==="tree"?"flex":"none";
  if(v==="list"&&!listBuilt)buildList();
  if(v==="tree")closePanel();
}

/* ════════════════════════════════════════════════════════
   LIST VIEW
════════════════════════════════════════════════════════ */
function buildList(){
  BREG=[];
  const lv=document.getElementById("listview");
  let html="";
  TREE.children.forEach(level=>{
    const lc=LC[level.level]||"#c9a84c";
    html+=`<div class="lv-level"><div class="lv-lhdr" style="color:${lc};border-left:2px solid ${lc}44" onclick="acc(this)"><span style="border-left:2px solid ${lc};padding-left:8px">${level.name} — ${level.subtitle||""}</span><span class="ct">›</span></div><div class="lv-lbody">`;
    (level.children||[]).forEach(subj=>{
      const sc=subj.color;
      html+=`<div class="lv-subject"><div class="lv-shdr" style="color:${sc}99" onclick="acc(this)"><span style="flex:1">${subj.name}</span><span style="font-size:8px;color:${sc}55;margin-right:4px">${(subj.children||[]).length}</span><span class="ct">›</span></div><div class="lv-sbody">`;
      (subj.children||[]).forEach((book,bi)=>{
        const idx=regBook(book,level.name,subj.name);
        const mc=book.mem?" is-mem":"",st=book.mem?"":`style="color:${sc}bb"`;
        html+=`<div class="lv-book"><span class="lv-book-num" style="color:${sc}44">${bi+1}</span><span class="lv-book-name${mc}" ${st} onclick="openBI(${idx})">${book.name}</span><div class="lv-book-actions"><a class="lv-btn" href="${book.info||"#"}" target="_blank" rel="noopener" onclick="event.stopPropagation()" title="Information">&#9432;</a><a class="lv-btn" href="${book.pdf||"#"}" target="_blank" rel="noopener" onclick="event.stopPropagation()" title="PDF">&#8659;</a><a class="lv-btn" href="${book.video||"#"}" target="_blank" rel="noopener" onclick="event.stopPropagation()" title="Recording">&#9654;</a></div></div>`;
      });
      html+=`</div></div>`;
    });
    html+=`</div></div>`;
  });
  lv.innerHTML=html;listBuilt=true;
}
function acc(el){el.classList.toggle("open");el.nextElementSibling.classList.toggle("open");}
function openBI(idx){const d=BREG[idx];if(d)openPanel(d,null);}

/* ════════════════════════════════════════════════════════
   SPLASH
════════════════════════════════════════════════════════ */
function dismissSplash(){
  const s=document.getElementById("splash");
  if(!s)return;
  s.style.transition="opacity .4s ease";
  s.style.opacity="0";
  setTimeout(()=>s.remove(),400);
}
setTimeout(()=>{const s=document.getElementById("splash");if(s)s.remove();},3450);

/* ════════════════════════════════════════════════════════
   INIT
════════════════════════════════════════════════════════ */
update(root);
svg.call(zoom.transform,d3.zoomIdentity.translate(W*.07,H/2).scale(.92));
window.addEventListener("resize",()=>svg.attr("width",window.innerWidth).attr("height",window.innerHeight));
if(window.innerWidth<700)setView("list");
</script>
</body>
