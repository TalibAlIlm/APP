<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Talib al-ʿIlm — Islamic Studies Roadmap</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=IBM+Plex+Mono:wght@300;400;500&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ── RESET & SEPIA THEME ─────────────────────────────── */
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0c0904;--bg2:#130f08;--bg3:#1c1510;
  --gold:#c9a84c;--gold2:#e8c97a;--gold3:#f5e2a8;
  --muted:#6b5a3e;--border:#2c1e10;--text:#e8d5b7;
  --panel-w:294px;
}
body{background:var(--bg);font-family:'IBM Plex Mono',monospace;overflow:hidden;width:100vw;height:100vh;color:var(--text)}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 45% at 12% 20%,rgba(201,168,76,.055) 0%,transparent 65%),
    radial-gradient(ellipse 40% 50% at 88% 80%,rgba(160,100,30,.04) 0%,transparent 60%),
    radial-gradient(ellipse 28% 28% at 50% 50%,rgba(201,168,76,.025) 0%,transparent 70%);}

/* ── BISMILLAH SPLASH ────────────────────────────────── */
#splash{
  position:fixed;inset:0;z-index:9999;
  background:#0c0904;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:18px;cursor:pointer;
  animation:splashOut 0.7s ease 2.6s forwards;
}
@keyframes splashOut{to{opacity:0;pointer-events:none}}
.splash-ornament{
  color:var(--gold);opacity:0;font-size:13px;letter-spacing:.4em;
  animation:splashIn .8s ease .2s forwards;
}
.splash-arabic{
  font-family:'Noto Naskh Arabic',serif;font-size:clamp(26px,5vw,46px);
  color:var(--gold2);opacity:0;text-align:center;line-height:1.5;
  text-shadow:0 0 40px rgba(232,201,122,.5),0 0 80px rgba(201,168,76,.25);
  animation:splashIn .9s ease .5s forwards;
}
.splash-english{
  font-family:'Cinzel',serif;font-size:11px;letter-spacing:.22em;
  text-transform:uppercase;color:var(--muted);opacity:0;
  animation:splashIn .7s ease 1s forwards;
}
.splash-line{width:120px;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);opacity:0;animation:splashIn .6s ease 1.3s forwards}
.splash-skip{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);opacity:0;animation:splashIn .5s ease 1.8s forwards}
@keyframes splashIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

/* ── HEADER ──────────────────────────────────────────── */
#header{
  position:fixed;top:0;left:0;right:0;height:46px;z-index:200;
  background:rgba(12,9,4,.97);border-bottom:1px solid var(--border);
  box-shadow:0 1px 20px rgba(0,0,0,.6);backdrop-filter:blur(14px);
  display:flex;align-items:center;padding:0 12px;gap:10px;
}
#header h1{font-family:'Cinzel',serif;font-size:11px;letter-spacing:.2em;color:var(--gold);
  white-space:nowrap;text-transform:uppercase;text-shadow:0 0 16px rgba(201,168,76,.3)}
.hsep{width:1px;height:18px;background:var(--border);flex-shrink:0}

/* Filter chips (legend) */
.legend{display:flex;align-items:center;gap:6px;flex-wrap:nowrap;overflow:hidden}
.chip{
  display:flex;align-items:center;gap:3px;
  font-size:8px;letter-spacing:.04em;color:var(--muted);white-space:nowrap;
  padding:2px 6px;border-radius:2px;border:1px solid transparent;
  cursor:pointer;transition:all .18s ease;user-select:none;
}
.chip:hover{border-color:rgba(255,255,255,.1);color:var(--text)}
.chip.active{color:#0c0904;border-color:transparent}
.chip .ld{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* Header buttons */
.hbtn{margin-left:auto;display:flex;gap:5px;flex-shrink:0}
.hbtn button{
  background:transparent;border:1px solid var(--border);color:var(--muted);
  font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.08em;
  padding:4px 8px;cursor:pointer;text-transform:uppercase;
  transition:all .18s ease;white-space:nowrap;
}
.hbtn button:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.07)}
.hbtn button.active{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.1)}
#btn-search{font-size:12px;padding:3px 8px}

/* ── SEARCH ──────────────────────────────────────────── */
#search-wrap{
  position:fixed;top:56px;left:50%;transform:translateX(-50%);
  z-index:500;width:420px;max-width:90vw;
  opacity:0;pointer-events:none;transition:opacity .22s ease;
}
#search-wrap.open{opacity:1;pointer-events:all}
#search-input{
  width:100%;padding:10px 14px;
  background:rgba(19,15,8,.98);border:1px solid var(--gold);
  color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:11px;
  outline:none;box-shadow:0 4px 24px rgba(0,0,0,.6);
}
#search-input::placeholder{color:var(--muted)}
#search-results{
  background:rgba(19,15,8,.98);border:1px solid var(--border);border-top:none;
  max-height:280px;overflow-y:auto;
}
#search-results::-webkit-scrollbar{width:3px}
#search-results::-webkit-scrollbar-thumb{background:var(--border)}
.sr-item{
  padding:8px 14px;cursor:pointer;border-bottom:1px solid var(--border);
  transition:background .14s;
}
.sr-item:hover{background:rgba(201,168,76,.07)}
.sr-name{font-size:10px;color:var(--text);line-height:1.3}
.sr-name.mem{color:var(--gold2)}
.sr-path{font-size:8px;color:var(--muted);margin-top:2px;letter-spacing:.05em}
.sr-none{padding:12px 14px;font-size:10px;color:var(--muted);text-align:center}

/* ── BREADCRUMB ──────────────────────────────────────── */
#breadcrumb{
  position:fixed;top:58px;left:16px;z-index:150;pointer-events:none;
  font-size:9px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;
  opacity:0;transition:opacity .35s;max-width:55vw;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
#breadcrumb.show{opacity:1}
#breadcrumb span{color:var(--gold2)}

/* ── CANVAS ──────────────────────────────────────────── */
#canvas{width:100%;height:100%;cursor:grab;display:block;position:relative;z-index:1}
#canvas:active{cursor:grabbing}

/* ── PANEL ───────────────────────────────────────────── */
#panel{
  position:fixed;right:calc(-1 * var(--panel-w));top:46px;bottom:0;
  width:var(--panel-w);background:rgba(19,15,8,.97);
  border-left:1px solid var(--border);box-shadow:-6px 0 28px rgba(0,0,0,.55);
  z-index:300;display:flex;flex-direction:column;
  transition:right .3s cubic-bezier(.34,1.2,.64,1);
  overflow-y:auto;backdrop-filter:blur(18px);
}
#panel.open{right:0}
#panel::-webkit-scrollbar{width:2px}
#panel::-webkit-scrollbar-thumb{background:var(--border)}
#panel-close{
  position:sticky;top:0;align-self:flex-end;margin:10px 10px -4px auto;
  background:none;border:none;color:var(--muted);font-size:15px;
  cursor:pointer;transition:color .18s;z-index:1;line-height:1;
}
#panel-close:hover{color:var(--gold)}
#panel-path{padding:12px 14px 0;font-size:9px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;line-height:1.9}
#panel-path span{color:var(--gold2)}
#panel-title{padding:10px 14px 12px;font-family:'Cinzel',serif;font-size:12px;color:var(--gold2);line-height:1.45;border:1px solid var(--border);border-left:none;border-right:none;margin-top:8px;text-shadow:0 0 14px rgba(232,201,122,.18)}
#panel-mem{padding:10px 14px 2px;font-size:9px;letter-spacing:.12em;color:var(--gold2);min-height:28px;text-shadow:0 0 8px rgba(232,201,122,.5)}
#panel-btns{padding:12px 14px 16px;display:flex;flex-direction:column;gap:7px}
.pbtn{
  display:flex;align-items:center;gap:10px;padding:10px 13px;
  border:1px solid var(--border);background:transparent;color:var(--text);
  font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.06em;
  cursor:pointer;text-align:left;transition:all .2s ease;
  text-decoration:none;width:100%;
}
.pbtn:hover{border-color:var(--gold);color:var(--gold2);background:rgba(201,168,76,.06);
  box-shadow:0 0 14px rgba(201,168,76,.1);transform:translateX(2px)}
.pbtn .icon{font-size:13px;width:18px;text-align:center;flex-shrink:0;opacity:.8}
#panel-note{padding:12px 14px 18px;font-size:9px;color:var(--muted);line-height:1.7;border-top:1px solid var(--border);margin-top:auto}

/* ── CONTROLS ────────────────────────────────────────── */
#controls{position:fixed;bottom:14px;right:14px;display:flex;gap:4px;z-index:150}
.cbtn{
  width:28px;height:28px;background:rgba(19,15,8,.9);
  border:1px solid var(--border);color:var(--muted);
  font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:all .18s;backdrop-filter:blur(8px);
}
.cbtn:hover{border-color:var(--gold);color:var(--gold);box-shadow:0 0 8px rgba(201,168,76,.2)}

#hint{
  position:fixed;bottom:14px;left:50%;transform:translateX(-50%);
  font-size:9px;letter-spacing:.08em;color:#2e2010;
  pointer-events:none;text-transform:uppercase;white-space:nowrap;transition:opacity .4s;
}

/* ── MINIMAP ─────────────────────────────────────────── */
#minimap{
  position:fixed;bottom:50px;left:14px;z-index:150;
  background:rgba(12,9,4,.9);border:1px solid var(--border);
  backdrop-filter:blur(8px);cursor:crosshair;
  box-shadow:0 2px 12px rgba(0,0,0,.4);
}
#minimap canvas{display:block}
#mm-label{
  font-family:'Cinzel',serif;font-size:7px;letter-spacing:.15em;
  color:var(--muted);text-transform:uppercase;text-align:center;
  padding:3px 0 2px;border-bottom:1px solid var(--border);
}

/* ── LIST VIEW ───────────────────────────────────────── */
#listview{position:fixed;top:46px;left:0;right:0;bottom:0;overflow-y:auto;background:var(--bg);display:none;z-index:50}
#listview.show{display:block}
#listview::-webkit-scrollbar{width:3px}
#listview::-webkit-scrollbar-thumb{background:var(--border)}
.lv-level{border-bottom:1px solid var(--border)}
.lv-lhdr{padding:13px 14px;font-family:'Cinzel',serif;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:space-between;user-select:none;transition:background .18s}
.lv-lhdr:hover{background:rgba(255,255,255,.018)}
.lv-lhdr .ct{font-size:10px;transition:transform .26s cubic-bezier(.4,0,.2,1);color:var(--muted);flex-shrink:0}
.lv-lhdr.open .ct{transform:rotate(90deg)}
.lv-lbody{max-height:0;overflow:hidden;transition:max-height .36s cubic-bezier(.4,0,.2,1)}
.lv-lbody.open{max-height:20000px}
.lv-subject{border-top:1px solid rgba(255,255,255,.032)}
.lv-shdr{padding:8px 22px;font-size:9px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:8px;user-select:none;transition:background .14s}
.lv-shdr:hover{background:rgba(255,255,255,.016)}
.lv-shdr .ct{transition:transform .2s cubic-bezier(.4,0,.2,1);color:var(--muted);margin-left:auto;flex-shrink:0}
.lv-shdr.open .ct{transform:rotate(90deg)}
.lv-sbody{max-height:0;overflow:hidden;transition:max-height .28s cubic-bezier(.4,0,.2,1);padding:0 28px}
.lv-sbody.open{max-height:5000px;padding-bottom:10px}
.lv-book{display:flex;align-items:center;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.02);gap:6px;min-height:29px}
.lv-book-num{font-size:8px;color:var(--muted);width:14px;flex-shrink:0;text-align:right}
.lv-book-name{font-size:9.5px;opacity:.72;flex:1;line-height:1.35;cursor:pointer;transition:opacity .14s}
.lv-book-name:hover{opacity:1}
.lv-book-name.is-mem{color:var(--gold2);opacity:1;text-shadow:0 0 8px rgba(232,201,122,.45),0 0 18px rgba(201,168,76,.22);animation:mem-pulse 3.2s ease-in-out infinite}
@keyframes mem-pulse{0%,100%{text-shadow:0 0 6px rgba(232,201,122,.4),0 0 14px rgba(201,168,76,.18)}50%{text-shadow:0 0 11px rgba(232,201,122,.7),0 0 26px rgba(201,168,76,.38)}}
.lv-book-actions{display:flex;gap:3px;flex-shrink:0}
.lv-btn{width:20px;height:20px;background:transparent;border:1px solid var(--border);color:var(--muted);font-size:9px;cursor:pointer;display:flex;align-items:center;justify-content:center;text-decoration:none;transition:all .15s;line-height:1}
.lv-btn:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.08)}
@media(max-width:680px){.legend{display:none}#header h1{font-size:9px}.hbtn button{font-size:8px;padding:3px 5px}}
</style>
</head>
<body>

<!-- ── BISMILLAH SPLASH ─────────────────────────────── -->
<div id="splash" onclick="dismissSplash()">
  <div class="splash-ornament">&#10022; &nbsp; &#10022; &nbsp; &#10022;</div>
  <div class="splash-arabic">&#xFDFD;</div>
  <div class="splash-line"></div>
  <div class="splash-english">In the name of Allah, the Most Gracious, the Most Merciful</div>
  <div class="splash-skip">Tap anywhere to continue</div>
</div>

<!-- ── HEADER ─────────────────────────────────────────── -->
<div id="header">
  <h1>Talib al-&#x02BF;Ilm</h1>
  <div class="hsep"></div>
  <div class="legend" id="legend-chips"></div>
  <div class="hbtn">
    <button id="btn-search" title="Search (Ctrl+F)" onclick="toggleSearch()">&#x2315;</button>
    <button id="btn-tree" class="active" onclick="setView('tree')">Tree</button>
    <button id="btn-list" onclick="setView('list')">List</button>
    <button onclick="expandAll()">Expand</button>
    <button onclick="collapseToLevels()">Collapse</button>
    <button onclick="resetZoom()">Reset</button>
    <button onclick="exportPDF()">PDF</button>
  </div>
</div>

<!-- ── SEARCH ─────────────────────────────────────────── -->
<div id="search-wrap">
  <input id="search-input" type="text" placeholder="Search texts…" oninput="onSearch(this.value)" onkeydown="onSearchKey(event)">
  <div id="search-results"></div>
</div>

<div id="breadcrumb"></div>
<svg id="canvas"></svg>

<!-- ── PANEL ─────────────────────────────────────────── -->
<div id="panel">
  <button id="panel-close" onclick="closePanel()">&#x2715;</button>
  <div id="panel-path"></div>
  <div id="panel-title"></div>
  <div id="panel-mem"></div>
  <div id="panel-btns">
    <a class="pbtn" id="btn-info"  href="#" target="_blank" rel="noopener"><span class="icon">&#9432;</span>Information</a>
    <a class="pbtn" id="btn-pdf"   href="#" target="_blank" rel="noopener"><span class="icon">&#128196;</span>PDF</a>
    <a class="pbtn" id="btn-video" href="#" target="_blank" rel="noopener"><span class="icon">&#9654;</span>Recording</a>
  </div>
  <div id="panel-note">Links will be added for each text.<br>Press Esc or click background to close.</div>
</div>

<div id="listview"></div>

<!-- ── MINIMAP ─────────────────────────────────────────── -->
<div id="minimap">
  <div id="mm-label">Map</div>
  <canvas id="mm-canvas" width="180" height="96"></canvas>
</div>

<!-- ── CONTROLS ─────────────────────────────────────────── -->
<div id="controls">
  <button class="cbtn" id="zoom-in">+</button>
  <button class="cbtn" id="zoom-out">&#8722;</button>
</div>
<div id="hint">Click level/subject to expand &nbsp;&bull;&nbsp; Click book for details &nbsp;&bull;&nbsp; Drag &amp; scroll to navigate</div>

<script>
// ════════════════════════════════════════════════════════
// COLOURS
// ════════════════════════════════════════════════════════
const SC={poems:"#a8d5e2",aqeedah:"#ef9a9a",fiqh:"#80cbc4",hadith:"#ffcc80",nahw:"#a5d6a7",tajweed:"#80deea",usool:"#ce93d8",tafsir:"#fff59d",faraid:"#c5e1a5",balagha:"#ffe082",adab:"#bcaaa4",seerah:"#f48fb1",mustalah:"#b39ddb",qawaid:"#b2dfdb",lit:"#e6ee9c",sarf:"#a5d6a7",illal:"#b39ddb",history:"#ffab91",poetry:"#ffe082"};
const LC={0:"#e0c97a",1:"#4caf50",2:"#42a5f5",3:"#ce93d8",4:"#ff8a65",5:"#c9a84c"};

// ════════════════════════════════════════════════════════
// DATA
// ════════════════════════════════════════════════════════
const b=(n,m=false,i="#",p="#",v="#")=>({name:n,mem:m,type:"book",info:i,pdf:p,video:v});
const s=(n,c,ch)=>({name:n,color:c,type:"subject",children:ch});

const TREE={name:"Talib al-Ilm",type:"root",children:[
{name:"Entry Level",subtitle:"First Steps",level:0,type:"level",children:[
  s("Short Poems — Amir Bahjat",SC.poems,[
    b("Mandhuma al-Tawhid wal-Iman",true),
    b("Mandhuma Ahsan al-Akhlaq",true),
    b("Al-Mandhuma al-Munira fi Muhimm Ilm al-Sira",true),
  ]),
  s("Adab — Entry",SC.adab,[
    b("Khulasa Ta'dhim al-Ilm — al-Usaymi",true),
    b("Adhkar wal-Adaab — Mutoon Series",true),
    b("Hisnul Muslim — Fortress of the Muslim",true),
  ]),
]},
{name:"Level I",subtitle:"Foundation",level:1,type:"level",children:[
  s("Aqeedah",SC.aqeedah,[
    b("Al-Usul al-Thalatha — The Three Fundamentals"),
    b("Al-Qawa'id al-Arba'a — The Four Principles"),
    b("Nawaqid al-Islam — Nullifiers of Islam"),
  ]),
  s("Fiqh",SC.fiqh,[
    b("Al-Nadhm al-Bayin fi al-Fiqh al-Mutayin"),
    b("Shurut al-Salah — Conditions, Pillars & Obligations"),
  ]),
  s("Hadith",SC.hadith,[b("Al-Arba'un al-Nawawiyya",true)]),
  s("Nahw — Arabic Grammar",SC.nahw,[
    b("Madinah Arabic Books (1–3)"),
    b("Al-Nahw al-Wadih"),
    b("Al-Ajurrumiyya"),
  ]),
  s("Tajweed",SC.tajweed,[b("Tuhfat al-Atfal")]),
  s("Usool al-Fiqh",SC.usool,[b("Al-Waraqat — al-Juwayni")]),
  s("Usool al-Tafsir",SC.tafsir,[b("Muqaddima fi Usool al-Tafsir — Ibn Taymiyya (Summary)")]),
  s("Fara'id — Inheritance",SC.faraid,[b("Al-Rahabiyya",true)]),
  s("Adab",SC.adab,[b("Hilyat Talib al-Ilm — Bakr Abu Zayd")]),
]},
{name:"Level II",subtitle:"Elementary",level:2,type:"level",children:[
  s("Aqeedah",SC.aqeedah,[
    b("Luma al-I'tiqad — Ibn Qudama"),
    b("Kitab al-Tawhid — Ibn Abd al-Wahhab"),
    b("Kashf al-Shubuhat"),
  ]),
  s("Nahw — Arabic Grammar",SC.nahw,[
    b("Mutammima al-Ajurrumiyya"),
    b("Nuzhat al-Huloom fi Nadhm al-Ajurrumiyya"),
  ]),
  s("Hadith",SC.hadith,[b("Umdat al-Ahkam — al-Maqdisi",true)]),
  s("Mustalah al-Hadith",SC.mustalah,[b("Al-Mandhuma al-Bayquniyya")]),
  s("Fiqh — Hanbali",SC.fiqh,[b("Akhsar al-Mukhtasarat — Ibn Balban")]),
  s("Fiqh — Shafi'i",SC.fiqh,[b("Matn al-Ghaya wal-Taqrib — Abu Shuja'")]),
  s("Fiqh — Maliki",SC.fiqh,[b("Al-Qayrawaniyya — Ibn Abi Zayd al-Qayrawani")]),
  s("Fiqh — Hanafi",SC.fiqh,[b("Mukhtasar al-Quduri")]),
  s("Tajweed / Qira'at",SC.tajweed,[
    b("Al-Muqaddima al-Jazariyya"),
    b("Na't al-Darajat fi Hukm al-Qira'at"),
    b("Al-Khaqaniyya"),
  ]),
  s("Usool al-Tafsir",SC.tafsir,[b("Mandhuma al-Zamzami fi Usool al-Tafsir",true)]),
  s("Usool al-Fiqh",SC.usool,[b("Al-Qawa'id wal-Usool al-Jami'a")]),
  s("Qawa'id Fiqhiyya",SC.qawaid,[b("Zubdat al-Qawa'id al-Fiqhiyya")]),
  s("Adab",SC.adab,[
    b("Mandhuma Abi Ishaq al-Ilbiri"),
    b("Mandhuma al-Adab al-Shar'iyya al-Sughra",true),
  ]),
  s("Seerah",SC.seerah,[b("Al-Urjuza al-Mi'iyya")]),
]},
{name:"Level III",subtitle:"Intermediate",level:3,type:"level",children:[
  s("Aqeedah",SC.aqeedah,[
    b("Al-Aqida al-Wasitiyya — Ibn Taymiyya"),
    b("Al-Qawl al-Mufid Sharh Kitab al-Tawhid — Ibn Uthaymin"),
    b("Fath al-Majid Sharh Kitab al-Tawhid"),
  ]),
  s("Nahw — Arabic Grammar",SC.nahw,[
    b("Shudhur al-Dhahab — Ibn Hisham"),
    b("Qatr al-Nada wa Ball al-Sada — Ibn Hisham"),
    b("Mulhat al-I'rab — al-Hariri"),
  ]),
  s("Sarf — Morphology",SC.sarf,[b("Lamiyyat al-Af'al — Ibn Malik")]),
  s("Hadith",SC.hadith,[b("Bulugh al-Maram — Ibn Hajar al-Asqalani",true)]),
  s("Mustalah al-Hadith",SC.mustalah,[
    b("Nukhbat al-Fikar — Ibn Hajar al-Asqalani"),
    b("Ikhtisar Ulum al-Hadith — Ibn Kathir"),
