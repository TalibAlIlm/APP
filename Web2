function toggleFilter(color,el,cat){
  if(activeFilters.has(color)){
    activeFilters.delete(color);
    el.classList.remove("active");
    el.style.background="";el.style.color="";
  } else {
    activeFilters.add(color);
    el.classList.add("active");
    el.style.background=color;el.style.color="#0c0904";
  }
  clearFocus();update(root);
}

// ════════════════════════════════════════════════════════
// MINIMAP
// ════════════════════════════════════════════════════════
const mmCanvas=document.getElementById("mm-canvas");
const mmCtx=mmCanvas.getContext("2d");
const MM_W=mmCanvas.width,MM_H=mmCanvas.height,MM_PAD=7;

document.getElementById("minimap").addEventListener("click",e=>{
  const rect=mmCanvas.getBoundingClientRect();
  const mx=e.clientX-rect.left,my=e.clientY-rect.top;
  const svgX=(mx-MM_PAD)/mmScale+mmMinX;
  const svgY=(my-MM_PAD)/mmScale+mmMinY;
  const ct=d3.zoomTransform(svg.node());
  svg.transition().duration(380).call(zoom.transform,d3.zoomIdentity.translate(W/2-svgX*ct.k,H/2-svgY*ct.k).scale(ct.k));
});

function updateMinimap(){
  mmCtx.clearRect(0,0,MM_W,MM_H);
  const visible=root.descendants().filter(d=>d.x0!==undefined);
  if(!visible.length)return;
  const xs=visible.map(d=>d.y),ys=visible.map(d=>d.x);
  mmMinX=Math.min(...xs);mmMinY=Math.min(...ys);
  const xRange=Math.max(...xs)-mmMinX||1,yRange=Math.max(...ys)-mmMinY||1;
  mmScale=Math.min((MM_W-MM_PAD*2)/xRange,(MM_H-MM_PAD*2)/yRange);
  const toX=v=>MM_PAD+(v-mmMinX)*mmScale;
  const toY=v=>MM_PAD+(v-mmMinY)*mmScale;

  // Links
  mmCtx.strokeStyle="rgba(180,140,60,0.18)";mmCtx.lineWidth=0.5;
  root.links().forEach(lk=>{
    if(!lk.source.y||!lk.target.y)return;
    mmCtx.beginPath();mmCtx.moveTo(toX(lk.source.y),toY(lk.source.x));mmCtx.lineTo(toX(lk.target.y),toY(lk.target.x));mmCtx.stroke();
  });
  // Nodes
  visible.forEach(d=>{
    const r=d.data.type==="root"?3:d.data.type==="level"?2:1.5;
    mmCtx.fillStyle=nodeColor(d)+(d.data.type==="book"?"80":"cc");
    mmCtx.beginPath();mmCtx.arc(toX(d.y),toY(d.x),r,0,Math.PI*2);mmCtx.fill();
  });
  // Viewport rect
  const ct=d3.zoomTransform(svg.node());
  const vx0=-ct.x/ct.k,vy0=-ct.y/ct.k,vx1=(W-ct.x)/ct.k,vy1=(H-ct.y)/ct.k;
  mmCtx.strokeStyle="rgba(232,201,122,0.55)";mmCtx.lineWidth=1;
  mmCtx.strokeRect(toX(vx0),toY(vy0),(vx1-vx0)*mmScale,(vy1-vy0)*mmScale);
}

