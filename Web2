svg.call(zoom).on("dblclick.zoom",null);
svg.on("click",()=>closePanel());
document.getElementById("zi").onclick=()=>zoom.scaleBy(svg,1.3);
document.getElementById("zo").onclick=()=>zoom.scaleBy(svg,.77);

const treeFn=d3.tree().nodeSize([20,264]);
let root=d3.hierarchy(TREE);

// Pre-set IDs for ALL nodes including collapsed ones — essential for reliable animation
let _nid=0;
(function preId(d){d.id=++_nid;(d.children||d._children||[]).forEach(preId);})(root);
root.descendants().forEach(d=>{if(d.depth>=2){d._children=d.children;d.children=null;}});
root.x0=0; root.y0=0;

/* ── Helpers ──────────────────────────────────────────── */
function nColor(d){
  if(d.data.type==="root")return"#c9a84c";
  if(d.data.type==="level")return LC[d.data.level]||"#c9a84c";
  if(d.data.type==="subject")return d.data.color||"#888";
  return(d.parent&&d.parent.data.color)||"#a0a0c0";
}
function nR(d){return d.data.type==="root"?13:d.data.type==="level"?9:d.data.type==="subject"?6:4;}
function nLabel(d){
  if(d.data.type==="root")return"Talib al-Ilm";
  if(d.data.type==="level")return d.data.name+" — "+(d.data.subtitle||"");
  if(d.data.type==="subject"){const n=(d.children||d._children||[]).length;return d.data.name+(n?` [${n}]`:"");}
  return d.data.name.length>38?d.data.name.slice(0,36)+"…":d.data.name;
}
function diag(d){
  const sx=d.source.y,sy=d.source.x,tx=d.target.y,ty=d.target.x,mx=(sx+tx)/2;
  return`M${sx},${sy}C${mx},${sy} ${mx},${ty} ${tx},${ty}`;
}
function nOpacity(d){
  if(focusedIds)return focusedIds.has(d.id)?1:0.05;
  if(activeFilters.size){
    if(d.data.type==="root"||d.data.type==="level")return 1;
    if(d.data.type==="subject")return activeFilters.has(d.data.color)?1:0.06;
    return(d.parent&&activeFilters.has(d.parent.data.color))?1:0.06;
  }
  return 1;
}
function lOpacity(d){
  if(focusedIds)return(focusedIds.has(d.source.id)&&focusedIds.has(d.target.id))?0.7:0.04;
  if(activeFilters.size){
    const t=d.target,tc=t.data.type==="subject"?t.data.color:t.data.type==="book"?(t.parent&&t.parent.data.color):null;
    return tc&&activeFilters.has(tc)?0.3:0.04;
  }
  return 0.22;
}

/* ── Update ───────────────────────────────────────────── */
let fillTimer;
function update(src){
  const td=treeFn(root);
  const nodes=td.descendants(), links=td.links();

  // Links — keyed by stable "sourceId-targetId"
  const lkSel=lkG.selectAll(".lk").data(links,d=>d.source.id+"-"+d.target.id);
  const lkE=lkSel.enter().append("path").attr("class","lk")
    .attr("fill","none").attr("stroke-width",".8px")
    .attr("d",()=>{const o={x:src.x0||0,y:src.y0||0};return diag({source:o,target:o});})
    .attr("stroke",d=>{const t=d.target;return t.data.type==="level"?LC[t.data.level]:t.data.type==="book"?(t.parent&&t.parent.data.color)||"#444":t.data.color||"#444";})
    .attr("opacity",0);
  lkSel.merge(lkE).transition().duration(280).ease(d3.easeCubicInOut)
    .attr("d",diag)
    .attr("stroke",d=>{const t=d.target;return t.data.type==="level"?LC[t.data.level]:t.data.type==="book"?(t.parent&&t.parent.data.color)||"#444":t.data.color||"#444";})
    .attr("opacity",lOpacity);
  lkSel.exit().transition().duration(280)
    .attr("d",()=>{const o={x:src.x,y:src.y};return diag({source:o,target:o});})
    .attr("opacity",0).remove();

  // Nodes
  const ndSel=ndG.selectAll(".nd").data(nodes,d=>d.id);
  const ndE=ndSel.enter().append("g").attr("class","nd")
    .attr("transform",()=>`translate(${src.y0||0},${src.x0||0})`).attr("opacity",0);
  ndE.append("circle")
    .attr("r",nR)
    .attr("fill",d=>nColor(d)+(d.data.type==="book"?"18":d.data.type==="subject"?"2c":"3e"))
    .attr("stroke",nColor).attr("stroke-width",d=>d.data.type==="root"?2:1.5);
  ndE.append("circle").attr("class","cd").attr("r",2.2).attr("fill",nColor).attr("opacity",0);
  ndE.append("text").attr("dy","0.31em").attr("pointer-events","none")
    .attr("font-size",d=>d.data.type==="root"?"12px":d.data.type==="level"?"10px":d.data.type==="subject"?"9px":"8.5px")
    .attr("font-weight",d=>d.data.mem?"500":"400")
    .attr("fill",d=>{if(d.data.mem&&d.data.type==="book")return"#e8c97a";const c=nColor(d);return d.data.type==="root"||d.data.type==="level"?c:d.data.type==="subject"?c+"cc":c+"99";})
    .attr("filter",d=>d.data.mem&&d.data.type==="book"?"url(#gm)":null)
    .attr("letter-spacing",d=>d.data.type==="level"?"0.1em":"0.03em")
    .text(nLabel);
  ndE.on("mouseover",function(e,d){
      if(d.data.type==="root")return;
      d3.select(this).select("circle").transition().duration(110).attr("r",nR(d)*1.36).attr("stroke-width",2);
    })
    .on("mouseout",function(e,d){
      d3.select(this).select("circle").transition().duration(170).attr("r",nR(d)).attr("stroke-width",d.data.type==="root"?2:1.5);
    })
    .on("click",handleClick);

  const mg=ndSel.merge(ndE);
  mg.transition().duration(280).ease(d3.easeCubicInOut)
    .attr("transform",d=>`translate(${d.y},${d.x})`).attr("opacity",nOpacity);
  mg.select("text")
    .attr("x",d=>{const r=nR(d);return(d.children||d._children)?-(r+5):(r+5);})
    .attr("text-anchor",d=>(d.children||d._children)?"end":"start");
  mg.select(".cd").attr("opacity",d=>d._children&&d.data.type!=="book"?.75:0);
  ndSel.exit().transition().duration(280).attr("transform",`translate(${src.y},${src.x})`).attr("opacity",0).remove();
  nodes.forEach(d=>{d.x0=d.x;d.y0=d.y;});

  clearTimeout(fillTimer);
  fillTimer=setTimeout(drawFills,300);
}

/* ── Level fills ─────────────────────────────────────── */
function drawFills(){
  bgG.selectAll("*").remove();
  root.each(lv=>{
    if(lv.data.type!=="level"||!lv.children||!lv.children.length)return;
    const all=lv.descendants();
    const xs=all.map(n=>n.y), ys=all.map(n=>n.x);
    const color=LC[lv.data.level]||"#c9a84c";
    bgG.append("rect")
      .attr("x",Math.min(...xs)-18).attr("y",Math.min(...ys)-16)
      .attr("width",Math.max(...xs)-Math.min(...xs)+240)
      .attr("height",Math.max(...ys)-Math.min(...ys)+32)
      .attr("rx",6).attr("fill",color+"08").attr("stroke",color+"1a").attr("stroke-width",.8);
  });
}

/* ── Animated path — OVERLAY approach (reliable, full path) ──
   Instead of animating existing link elements (timing issues),
   we READ their final rendered path and draw fresh overlay paths.
   This guarantees the animation reaches every node including books. */
function animatePath(d){
  animG.selectAll("*").remove();
  const anc=d.ancestors().reverse(); // [root, level, subject, book]
  const DASH=2000;

  anc.forEach((node,i)=>{
    if(i>=anc.length-1)return;
    const nxt=anc[i+1];
    // Read the rendered 'd' attribute from the existing link element
    let pathD=null;
    lkG.selectAll(".lk").each(function(ld){
      if(!pathD && ld.source.id===node.id && ld.target.id===nxt.id){
        pathD=this.getAttribute("d");
      }
    });
    if(!pathD)return;

    // Create a glow overlay — separate SVG filter defined inline
    const overlay=animG.append("path")
      .attr("fill","none")
      .attr("d",pathD)
      .attr("stroke","#e8c97a")
      .attr("stroke-width",2.6)
      .attr("stroke-linecap","round")
      .attr("stroke-dasharray",`${DASH} ${DASH}`)
      .attr("stroke-dashoffset",DASH)
      .attr("opacity",1);

    // Glow via filter on each overlay element
    overlay.style("filter","drop-shadow(0 0 4px #e8c97a) drop-shadow(0 0 8px rgba(201,168,76,.6))");

    overlay.transition()
      .delay(i*240)
      .duration(400)
      .ease(d3.easeCubicInOut)
      .attr("stroke-dashoffset",0);
  });
}

function clearAnimPath(){animG.selectAll("*").remove();}

/* ── Click handler ───────────────────────────────────── */
function handleClick(event,d){
  event.stopPropagation();
  if(d.data.type==="book"){focusNode(d);openPanel(d.data,d);return;}
  d.children?(d._children=d.children,d.children=null):(d.children=d._children,d._children=null);
  clearFocus();update(d);
}

function focusNode(d){
  const anc=d.ancestors();
  focusedIds=new Set(anc.map(a=>a.id));
  focusedIds.add(d.id);
  update(d);
  // Run animation after tree transitions complete
  setTimeout(()=>animatePath(d),300);
  const parts=anc.reverse().map(a=>a.data.type==="root"?null:a.data.name).filter(Boolean);
  parts.push(d.data.name.length>28?d.data.name.slice(0,26)+"…":d.data.name);
  const bc=document.getElementById("breadcrumb");
  bc.innerHTML=parts.map((p,i)=>i===parts.length-1?`<span>${p}</span>`:p).join(" ›&nbsp;");
  bc.classList.add("show");
}

function clearFocus(){
  focusedIds=null;
  clearAnimPath();
  document.getElementById("breadcrumb").classList.remove("show");
  ndG.selectAll(".nd").transition().duration(260).attr("opacity",nOpacity);
  lkG.selectAll(".lk").transition().duration(260).attr("opacity",lOpacity);
}

/* ════════════════════════════════════════════════════════
   PANEL
════════════════════════════════════════════════════════ */
function openPanel(data,treeNode){
  document.getElementById("panel-title").textContent=data.name;
  let ph="";
  if(treeNode){
    ph=treeNode.ancestors().reverse()
      .map(a=>a.data.type==="root"?null:
           (a.data.type==="level"||a.data.type==="subject")?`<span>${a.data.name}</span>`:null)
      .filter(Boolean).join("&nbsp;›&nbsp;");
  } else if(data.ln){
    ph=`<span>${data.ln}</span>&nbsp;›&nbsp;<span>${data.sn}</span>`;
  }
  document.getElementById("panel-path").innerHTML=ph;
  document.getElementById("panel-mem").textContent=data.mem?"✦ Memorize this text":"";
  document.getElementById("btn-info").href=data.info||"#";
  document.getElementById("btn-pdf").href=data.pdf||"#";
  document.getElementById("btn-video").href=data.video||"#";
  document.getElementById("panel").classList.add("open");
  document.getElementById("hint").style.opacity="0";
}
function closePanel(){
  document.getElementById("panel").classList.remove("open");
  document.getElementById("hint").style.opacity="1";
  clearFocus();
}
document.addEventListener("keydown",e=>{
  if(e.key==="Escape"){closePanel();closeSearch();}
  if((e.ctrlKey||e.metaKey)&&e.key==="f"){e.preventDefault();toggleSearch();}
});

/* ════════════════════════════════════════════════════════
   SEARCH
════════════════════════════════════════════════════════ */
let _hits=[];
function toggleSearch(){
  const w=document.getElementById("search-wrap");
  const opening=!w.classList.contains("open");
  w.classList.toggle("open",opening);
  if(opening)setTimeout(()=>document.getElementById("search-input").focus(),30);
  else resetSearch();
}
function closeSearch(){document.getElementById("search-wrap").classList.remove("open");resetSearch();}
function resetSearch(){document.getElementById("search-input").value="";document.getElementById("search-results").innerHTML="";}
function onSearch(q){
  const el=document.getElementById("search-results");
  if(!q.trim()){el.innerHTML="";return;}
  _hits=SI.filter(bk=>bk.name.toLowerCase().includes(q.toLowerCase())).slice(0,14);
  if(!_hits.length){el.innerHTML=`<div class="sr-none">No results</div>`;return;}
  el.innerHTML=_hits.map((bk,i)=>`<div class="sr-item" onclick="jumpToBook(${i})">
    <div class="sr-name${bk.mem?" mem":""}">${bk.name}</div>
    <div class="sr-path">${bk.ln}&nbsp;›&nbsp;${bk.sn}</div>
  </div>`).join("");
}

function jumpToBook(i){
  const target=_hits[i];
  if(!target)return;
  closeSearch();
  // Traverse all nodes (including _children) to find the hierarchy node
  let found=null;
  (function find(d){
    if(!found&&d.data.name===target.name&&d.data.type==="book"){found=d;return;}
    (d.children||d._children||[]).forEach(find);
  })(root);
  if(!found)return;
  // Expand ancestors
  found.ancestors().forEach(a=>{if(a._children){a.children=a._children;a._children=null;}});
  update(root);
  setTimeout(()=>{
    treeFn(root); // ensure positions are fresh
    const k=Math.max(d3.zoomTransform(svg.node()).k,0.8);
    svg.transition().duration(460).ease(d3.easeCubicInOut)
      .call(zoom.transform,d3.zoomIdentity.translate(W/2-found.y*k,H/2-found.x*k).scale(k));
    focusNode(found);
    openPanel(found.data,found);
  },310);
}

