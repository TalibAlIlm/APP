  width: 100vw;
  height: 100vh;
  color: #c9a84c;
}

#canvas {
  width: 100%;
  height: 100%;
  cursor: grab;
}
#canvas:active { cursor: grabbing; }

/* Header bar */
#header {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 48px;
  background: rgba(8,7,5,0.92);
  border-bottom: 1px solid #2a2010;
  display: flex;
  align-items: center;
  padding: 0 20px;
  gap: 20px;
  z-index: 100;
  backdrop-filter: blur(8px);
}

#header h1 {
  font-family: 'Cinzel', serif;
  font-size: 14px;
  letter-spacing: 0.15em;
  color: #c9a84c;
  white-space: nowrap;
}

.header-sep {
  width: 1px;
  height: 20px;
  background: #2a2010;
}

.legend {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  letter-spacing: 0.05em;
  color: #7a6840;
}

.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

/* Instructions */
#hint {
  position: fixed;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 10px;
  letter-spacing: 0.1em;
  color: #3a3020;
  text-transform: uppercase;
  pointer-events: none;
}

/* Tooltip */
#tooltip {
  position: fixed;
  background: #100e08;
  border: 1px solid #3a2e18;
  border-left: 2px solid #c9a84c;
  padding: 10px 14px;
  font-size: 11px;
  line-height: 1.7;
  max-width: 260px;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.15s;
  z-index: 200;
}

#tooltip .tt-title {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  color: #c9a84c;
  margin-bottom: 4px;
}

#tooltip .tt-arabic {
  font-size: 13px;
  color: #e8c97a;
  margin-bottom: 4px;
  direction: rtl;
}

#tooltip .tt-author {
  color: #7a6840;
  font-size: 10px;
  margin-bottom: 4px;
}

#tooltip .tt-meta {
  color: #9a8860;
  font-size: 10px;
}

#tooltip .tt-mem {
  color: #c9a84c;
  font-size: 10px;
}

/* SVG node/link styles */
.link {
  fill: none;
  stroke-width: 1px;
  opacity: 0.35;
}

.node circle {
  stroke-width: 1.5px;
  cursor: pointer;
  transition: r 0.2s, opacity 0.2s;
}

.node circle:hover {
  opacity: 0.85;
}

.node text {
  font-family: 'IBM Plex Mono', monospace;
  pointer-events: none;
  dominant-baseline: middle;
}

.node.root circle { cursor: default; }

/* Reset / zoom controls */
#controls {
  position: fixed;
  bottom: 16px;
  right: 16px;
  display: flex;
  gap: 6px;
  z-index: 100;
}

.ctrl-btn {
  width: 32px;
  height: 32px;
  background: #120f08;
  border: 1px solid #2a2010;
  color: #c9a84c;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'IBM Plex Mono', monospace;
  transition: background 0.15s;
}
.ctrl-btn:hover { background: #1e1a10; }
