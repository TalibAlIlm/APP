<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Talib al-Ilm — Islamic Studies Roadmap</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#07060a;--bg2:#0f0d14;--bg3:#161422;
  --gold:#c9a84c;--gold2:#e8c97a;--muted:#4a4260;
  --border:#1e1b2e;--text:#d4cce8;
}
body{background:var(--bg);font-family:'IBM Plex Mono',monospace;overflow:hidden;width:100vw;height:100vh;color:var(--text)}

/* ── HEADER ── */
#header{position:fixed;top:0;left:0;right:0;height:46px;background:rgba(7,6,10,.95);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:14px;z-index:200;backdrop-filter:blur(10px)}
#header h1{font-family:'Cinzel',serif;font-size:12px;letter-spacing:.18em;color:var(--gold);white-space:nowrap;text-transform:uppercase}
.hsep{width:1px;height:18px;background:var(--border)}
.legend{display:flex;align-items:center;gap:10px;flex-wrap:wrap;overflow:hidden}
.li{display:flex;align-items:center;gap:4px;font-size:9px;letter-spacing:.04em;color:var(--muted);white-space:nowrap}
.ld{width:7px;height:7px;border-radius:50%}
.hbtn{margin-left:auto;display:flex;gap:6px;flex-shrink:0}
.hbtn button{background:transparent;border:1px solid var(--border);color:var(--muted);font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.1em;padding:4px 9px;cursor:pointer;text-transform:uppercase;transition:all .2s}
.hbtn button:hover,.hbtn button.active{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.08)}

/* ── CANVAS ── */
#canvas{width:100%;height:100%;cursor:grab}
#canvas:active{cursor:grabbing}

/* ── BREADCRUMB ── */
#breadcrumb{position:fixed;top:56px;left:16px;font-size:9px;letter-spacing:.1em;color:var(--muted);z-index:150;pointer-events:none;text-transform:uppercase;transition:opacity .3s;opacity:0}
#breadcrumb.show{opacity:1}
#breadcrumb span{color:var(--gold)}

/* ── BOOK PANEL ── */
#panel{position:fixed;right:-320px;top:46px;bottom:0;width:300px;background:var(--bg2);border-left:1px solid var(--border);z-index:300;display:flex;flex-direction:column;transition:right .3s cubic-bezier(.4,0,.2,1)}
#panel.open{right:0}
#panel-close{position:absolute;top:12px;right:12px;background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;line-height:1}
#panel-close:hover{color:var(--gold)}
#panel-path{padding:16px 16px 0;font-size:9px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;line-height:1.8}
#panel-path span{color:var(--gold)}
#panel-title{padding:12px 16px 8px;font-family:'Cinzel',serif;font-size:14px;color:var(--gold2);line-height:1.35;border-bottom:1px solid var(--border)}
#panel-mem{padding:8px 16px 0;font-size:10px;letter-spacing:.1em;color:#c9a84c}
#panel-btns{padding:20px 16px;display:flex;flex-direction:column;gap:10px}
.pbtn{display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid var(--border);background:transparent;color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.06em;cursor:pointer;text-align:left;transition:all .2s;text-decoration:none}
.pbtn:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.06)}
.pbtn .icon{font-size:14px;width:20px;text-align:center;flex-shrink:0}
#panel-note{padding:0 16px;font-size:10px;color:var(--muted);line-height:1.6;border-top:1px solid var(--border);padding-top:14px}

/* ── CONTROLS ── */
#controls{position:fixed;bottom:16px;right:16px;display:flex;gap:5px;z-index:150}
.cbtn{width:30px;height:30px;background:var(--bg2);border:1px solid var(--border);color:var(--muted);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.cbtn:hover{border-color:var(--gold);color:var(--gold)}

#hint{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);font-size:9px;letter-spacing:.1em;color:var(--muted);pointer-events:none;text-transform:uppercase;transition:opacity .5s}

/* ── MOBILE LIST VIEW ── */
#listview{position:fixed;top:46px;left:0;right:0;bottom:0;overflow-y:auto;background:var(--bg);display:none;z-index:50}
#listview.show{display:block}
#listview::-webkit-scrollbar{width:4px}
#listview::-webkit-scrollbar-track{background:var(--bg)}
#listview::-webkit-scrollbar-thumb{background:var(--border)}

.lv-level{border-bottom:1px solid var(--border)}
.lv-level-hdr{padding:14px 16px;font-family:'Cinzel',serif;font-size:12px;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:space-between;user-select:none}
.lv-level-hdr:hover{background:rgba(255,255,255,.02)}
.lv-level-hdr .caret{font-size:10px;transition:transform .25s;color:var(--muted)}
.lv-level-hdr.open .caret{transform:rotate(90deg)}
.lv-level-body{display:none}
.lv-level-body.open{display:block}

.lv-subject{border-top:1px solid var(--border)}
.lv-subj-hdr{padding:10px 24px;font-size:10px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:space-between;user-select:none;color:var(--muted)}
.lv-subj-hdr:hover{background:rgba(255,255,255,.02)}
.lv-subj-hdr.open .caret{transform:rotate(90deg)}
.lv-subj-body{display:none;padding:0 32px 8px}
.lv-subj-body.open{display:block}

.lv-book{padding:8px 0;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,.03);cursor:pointer}
.lv-book:hover .lv-book-name{opacity:1}
.lv-book-name{font-size:10px;color:var(--text);opacity:.7;transition:opacity .2s;line-height:1.4}
.lv-book-mem{font-size:8px;color:var(--gold);margin-left:8px;white-space:nowrap}
.lv-book-arrow{font-size:10px;color:var(--muted);margin-left:8px;flex-shrink:0}

/* ── D3 styles ── */
.link{fill:none;stroke-width:.8px}
.node{cursor:pointer}
.node circle{stroke-width:1.5px}
.node text{pointer-events:none;dominant-baseline:middle}
.dimmed{opacity:.06!important;transition:opacity .3s}
.focused{opacity:1!important;transition:opacity .3s}

@media(max-width:680px){
  .legend{display:none}
  #header h1{font-size:10px}
}
</style>
</head>
<body>

