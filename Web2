function buildList(){
  BOOK_REG=[];
  const lv=document.getElementById("listview");
  let html="";
  TREE.children.forEach(level=>{
    const lc=LC[level.level]||"#c9a84c";
    html+=`<div class="lv-level"><div class="lv-lhdr" style="color:${lc};border-left:2px solid ${lc}44" onclick="toggleAcc(this)"><span style="border-left:2px solid ${lc};padding-left:8px">${level.name} — ${level.subtitle||""}</span><span class="ct">&#x203A;</span></div><div class="lv-lbody">`;
    (level.children||[]).forEach(subj=>{
      const sc=subj.color;
      html+=`<div class="lv-subject"><div class="lv-shdr" style="color:${sc}99" onclick="toggleAcc(this)"><span style="flex:1">${subj.name}</span><span style="font-size:8px;color:${sc}55;margin-right:4px">${(subj.children||[]).length}</span><span class="ct">&#x203A;</span></div><div class="lv-sbody">`;
      (subj.children||[]).forEach((book,bi)=>{
        const idx=regBook(book,level.name,subj.name);
        const mc=book.mem?" is-mem":"";
        const st=book.mem?"":`style="color:${sc}bb"`;
        html+=`<div class="lv-book"><span class="lv-book-num" style="color:${sc}44">${bi+1}</span><span class="lv-book-name${mc}" ${st} onclick="openBookByIdx(${idx})">${book.name}</span><div class="lv-book-actions"><a class="lv-btn" href="${book.info||"#"}" target="_blank" rel="noopener" title="Information" onclick="event.stopPropagation()">&#9432;</a><a class="lv-btn" href="${book.pdf||"#"}" target="_blank" rel="noopener" title="PDF" onclick="event.stopPropagation()">&#8659;</a><a class="lv-btn" href="${book.video||"#"}" target="_blank" rel="noopener" title="Recording" onclick="event.stopPropagation()">&#9654;</a></div></div>`;
      });
      html+=`</div></div>`;
    });
    html+=`</div></div>`;
  });
  lv.innerHTML=html;listBuilt=true;
}
function toggleAcc(el){el.classList.toggle("open");el.nextElementSibling.classList.toggle("open");}
function openBookByIdx(idx){const data=BOOK_REG[idx];if(data)openPanel(data,null);}

