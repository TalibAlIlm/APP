document.getElementById("zoom-in").onclick=()=>zoom.scaleBy(svg,1.3);
document.getElementById("zoom-out").onclick=()=>zoom.scaleBy(svg,.77);

const treeFn=d3.tree().nodeSize([20,264]);
let root=d3.hierarchy(TREE);
root.descendants().forEach(d=>{if(d.depth>=2){d._children=d.children;d.children=null;}});
root.x0=0;root.y0=0;

// ── Helpers ──────────────────────────────────────────────
function nodeColor(d){
  if(d.data.type==="root")return"#c9a84c";
  if(d.data.type==="level")return LC[d.data.level]||"#c9a84c";
  if(d.data.type==="subject")return d.data.color||"#888";
  return(d.parent&&d.parent.data.color)||"#a0a0c0";
}
function nodeR(d){return d.data.type==="root"?13:d.data.type==="level"?9:d.data.type==="subject"?6:4;}
function nodeLabel(d){
  if(d.data.type==="root")return"Talib al-Ilm";
  if(d.data.type==="level")return d.data.name+" — "+(d.data.subtitle||"");
  if(d.data.type==="subject"){const n=(d.children||d._children||[]).length;return d.data.name+(n?` [${n}]`:"");}
  const nm=d.data.name.length>38?d.data.name.slice(0,36)+"…":d.data.name;
  return nm;
}
function diag(d){const sx=d.source.y,sy=d.source.x,tx=d.target.y,ty=d.target.x,mx=(sx+tx)/2;return`M${sx},${sy}C${mx},${sy} ${mx},${ty} ${tx},${ty}`;}
function nodeOpacity(d){
  if(focusedIds)return focusedIds.has(d.id)?1:0.05;
  if(activeFilters.size){
    if(d.data.type==="root"||d.data.type==="level")return 1;
    if(d.data.type==="subject")return activeFilters.has(d.data.color)?1:0.06;
    return(d.parent&&activeFilters.has(d.parent.data.color))?1:0.06;
  }
  return 1;
}
function linkOpacity(d){
  if(focusedIds)return(focusedIds.has(d.source.id)&&focusedIds.has(d.target.id))?0.85:0.04;
  if(activeFilters.size){
    const tc=d.target.data.type==="subject"?d.target.data.color:d.target.data.type==="book"?(d.target.parent&&d.target.parent.data.color):null;
    return tc&&activeFilters.has(tc)?0.35:0.04;
  }
  return 0.22;
}

// ── Main update ──────────────────────────────────────────
let fillTimer;
function update(src){
  const td=treeFn(root);
  const nodes=td.descendants(),links=td.links();

  // Links
  const link=linksGroup.selectAll(".link").data(links,d=>d.target.id);
  const le=link.enter().insert("path",":first-child")
    .attr("class","link").attr("fill","none").attr("stroke-width",".8px")
    .attr("d",()=>{const o={x:src.x0||0,y:src.y0||0};return diag({source:o,target:o});})
    .attr("stroke",d=>{const t=d.target;return t.data.type==="level"?LC[t.data.level]:t.data.type==="book"?(t.parent&&t.parent.data.color)||"#444":t.data.color||"#444";})
    .attr("opacity",0);
  link.merge(le).transition().duration(290)
    .attr("d",diag)
    .attr("stroke",d=>{const t=d.target;return t.data.type==="level"?LC[t.data.level]:t.data.type==="book"?(t.parent&&t.parent.data.color)||"#444":t.data.color||"#444";})
    .attr("opacity",linkOpacity);
  link.exit().transition().duration(290).attr("d",()=>{const o={x:src.x,y:src.y};return diag({source:o,target:o});}).attr("opacity",0).remove();

  // Nodes
  const node=nodesGroup.selectAll(".node").data(nodes,d=>d.id||(d.id=++nodeId));
  const ne=node.enter().append("g").attr("class","node")
    .attr("transform",()=>`translate(${src.y0||0},${src.x0||0})`).attr("opacity",0);

  ne.append("circle")
    .attr("r",nodeR).attr("stroke-width",d=>d.data.type==="root"?2:1.5)
    .attr("fill",d=>nodeColor(d)+(d.data.type==="book"?"18":d.data.type==="subject"?"2c":"3e"))
    .attr("stroke",nodeColor);
  ne.append("circle").attr("class","cd").attr("r",2.2).attr("fill",nodeColor).attr("opacity",0);
  ne.append("text").attr("dy","0.31em")
    .attr("font-size",d=>d.data.type==="root"?"12px":d.data.type==="level"?"10px":d.data.type==="subject"?"9px":"8.5px")
    .attr("font-weight",d=>d.data.mem?"500":"400")
    .attr("fill",d=>{if(d.data.mem&&d.data.type==="book")return"#e8c97a";const c=nodeColor(d);return d.data.type==="root"||d.data.type==="level"?c:d.data.type==="subject"?c+"cc":c+"99";})
    .attr("filter",d=>d.data.mem&&d.data.type==="book"?"url(#glow-gold)":null)
    .attr("letter-spacing",d=>d.data.type==="level"?"0.1em":"0.03em")
    .text(nodeLabel);

  // Hover
  ne.on("mouseover",function(e,d){
      if(d.data.type==="root")return;
      d3.select(this).select("circle").transition().duration(120).attr("r",nodeR(d)*1.38).attr("stroke-width",2);
    })
    .on("mouseout",function(e,d){
      d3.select(this).select("circle").transition().duration(180).attr("r",nodeR(d)).attr("stroke-width",d.data.type==="root"?2:1.5);
    })
    .on("click",handleNodeClick);

  const merged=node.merge(ne);
  merged.transition().duration(290).ease(d3.easeCubicOut)
    .attr("transform",d=>`translate(${d.y},${d.x})`)
    .attr("opacity",nodeOpacity);
  merged.select("text")
    .attr("x",d=>{const r=nodeR(d);return(d.children||d._children)?-(r+5):(r+5);})
    .attr("text-anchor",d=>(d.children||d._children)?"end":"start");
  merged.select(".cd").attr("opacity",d=>d._children&&d.data.type!=="book"?.75:0);
  node.exit().transition().duration(290).attr("transform",`translate(${src.y},${src.x})`).attr("opacity",0).remove();
  nodes.forEach(d=>{d.x0=d.x;d.y0=d.y;});

  // Schedule fills and minimap after transitions
  clearTimeout(fillTimer);
  fillTimer=setTimeout(()=>{drawLevelFills();updateMinimap();},310);
}

// ── Level fills ──────────────────────────────────────────
function drawLevelFills(){
  bgGroup.selectAll("*").remove();
  root.each(lNode=>{
    if(lNode.data.type!=="level"||!lNode.children||!lNode.children.length)return;
    const all=lNode.descendants();
    const xs=all.map(n=>n.y),ys=all.map(n=>n.x);
    const x0=Math.min(...xs)-18,x1=Math.max(...xs)+230;
    const y0=Math.min(...ys)-16,y1=Math.max(...ys)+16;
    const color=LC[lNode.data.level]||"#c9a84c";
    bgGroup.append("rect")
      .attr("x",x0).attr("y",y0).attr("width",x1-x0).attr("height",y1-y0)
      .attr("rx",6).attr("ry",6)
      .attr("fill",color+"08").attr("stroke",color+"20").attr("stroke-width",.8);
  });
}

// ── Animated path ─────────────────────────────────────────
function animatePath(d){
  const anc=d.ancestors().reverse(); // root→level→subject→book
  anc.forEach((node,i)=>{
    if(i>=anc.length-1)return;
    const next=anc[i+1];
    linksGroup.selectAll(".link").filter(function(ld){
      return ld.source.id===node.id&&ld.target.id===next.id;
    }).each(function(){
      const el=this,len=el.getTotalLength();
      d3.select(el)
        .attr("stroke-dasharray",`${len} ${len}`)
        .attr("stroke-dashoffset",len)
        .attr("stroke","#e8c97a").attr("stroke-width",2.2)
        .attr("opacity",1).attr("filter","url(#glow-path)")
        .transition().delay(i*210).duration(360).ease(d3.easeCubicOut)
        .attr("stroke-dashoffset",0);
    });
  });
}

function resetLinkStyles(){
  linksGroup.selectAll(".link")
    .attr("stroke-dasharray",null).attr("stroke-dashoffset",null)
    .attr("stroke-width",".8px").attr("filter",null);
}

// ── Node click ────────────────────────────────────────────
function handleNodeClick(event,d){
  event.stopPropagation();
  if(d.data.type==="book"){focusNode(d);openPanel(d.data,d);return;}
  d.children?(d._children=d.children,d.children=null):(d.children=d._children,d._children=null);
  clearFocus();update(d);
}

function focusNode(d){
  const anc=d.ancestors();
  focusedIds=new Set(anc.map(a=>a.id));focusedIds.add(d.id);
  update(d);
  setTimeout(()=>animatePath(d),310);
  const parts=anc.reverse().map(a=>a.data.type==="root"?null:a.data.name).filter(Boolean);
  parts.push(d.data.name.length>28?d.data.name.slice(0,26)+"…":d.data.name);
  const bc=document.getElementById("breadcrumb");
  bc.innerHTML=parts.map((p,i)=>i===parts.length-1?`<span>${p}</span>`:p).join(" ›&nbsp;");
  bc.classList.add("show");
}

function clearFocus(){
  if(!focusedIds&&!document.getElementById("breadcrumb").classList.contains("show"))return;
  focusedIds=null;
  document.getElementById("breadcrumb").classList.remove("show");
  resetLinkStyles();
  nodesGroup.selectAll(".node").transition().duration(280).attr("opacity",nodeOpacity);
  linksGroup.selectAll(".link").transition().duration(280).attr("opacity",linkOpacity);
}

