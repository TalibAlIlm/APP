    <div class="li"><div class="ld" style="background:#b2dfdb"></div>Qawa&#x02BF;id</div>
    <div class="li"><div class="ld" style="background:#e6ee9c"></div>Literature</div>
  </div>
  <div class="hbtn">
    <button id="btn-tree" class="active" onclick="setView('tree')">Tree</button>
    <button id="btn-list" onclick="setView('list')">List</button>
    <button onclick="expandAll()">Expand</button>
    <button onclick="collapseToLevels()">Collapse</button>
    <button onclick="resetZoom()">Reset</button>
  </div>
</div>

<div id="breadcrumb"></div>
<svg id="canvas"></svg>

<!-- ── PANEL ─────────────────────────────────────────── -->
<div id="panel">
  <button id="panel-close" onclick="closePanel()">&#x2715;</button>
  <div id="panel-path"></div>
  <div id="panel-title"></div>
  <div id="panel-mem"></div>
  <div id="panel-btns">
    <a class="pbtn" id="btn-info" href="#" target="_blank" rel="noopener">
      <span class="icon">&#9432;</span>Information
    </a>
    <a class="pbtn" id="btn-pdf" href="#" target="_blank" rel="noopener">
      <span class="icon">&#128196;</span>PDF
    </a>
    <a class="pbtn" id="btn-video" href="#" target="_blank" rel="noopener">
      <span class="icon">&#9654;</span>Recording
    </a>
  </div>
  <div id="panel-note">Links will be added for each text.<br>Press Esc or click the background to close.</div>
</div>

<div id="listview"></div>

<div id="controls">
  <button class="cbtn" id="zoom-in" title="Zoom in">+</button>
  <button class="cbtn" id="zoom-out" title="Zoom out">&#8722;</button>
</div>
<div id="hint">Click level/subject to expand &nbsp;&bull;&nbsp; Click book for details &nbsp;&bull;&nbsp; Drag &amp; scroll to navigate</div>

<!-- ── SCRIPT ─────────────────────────────────────────── -->
<script>
