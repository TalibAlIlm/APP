const SI=[];
(function idx(node,ln,sn){
  if(node.type==="book"){SI.push({...node,ln,sn});return;}
  (node.children||[]).forEach(c=>idx(c,node.type==="level"?node.name:ln,node.type==="subject"?node.name:sn));
})(TREE,"","");

