let searchOpen=false;
function toggleSearch(){
  searchOpen=!searchOpen;
  const w=document.getElementById("search-wrap");
  w.classList.toggle("open",searchOpen);
  if(searchOpen){setTimeout(()=>document.getElementById("search-input").focus(),50);}
  else{document.getElementById("search-input").value="";document.getElementById("search-results").innerHTML="";}
}
function closeSearch(){searchOpen=false;document.getElementById("search-wrap").classList.remove("open");document.getElementById("search-input").value="";document.getElementById("search-results").innerHTML="";}
function onSearch(q){
  const el=document.getElementById("search-results");
  if(!q.trim()){el.innerHTML="";return;}
  const ql=q.toLowerCase();
  const hits=searchIndex.filter(b=>b.name.toLowerCase().includes(ql)).slice(0,12);
  if(!hits.length){el.innerHTML=`<div class="sr-none">No results</div>`;return;}
  el.innerHTML=hits.map((b,i)=>`<div class="sr-item" onclick="navigateToBook(${i},'${q.replace(/'/g,"\\'")}')">
    <div class="sr-name${b.mem?" mem":""}">${b.name}</div>
    <div class="sr-path">${b.levelName} › ${b.subjName}</div>
  </div>`).join("");
  el._hits=hits;
}
function onSearchKey(e){if(e.key==="Escape")closeSearch();}
function navigateToBook(i,q){
  const el=document.getElementById("search-results");
  const hits=el._hits||(searchIndex.filter(b=>b.name.toLowerCase().includes(q.toLowerCase())).slice(0,12));
  const target=hits[i];if(!target)return;
  closeSearch();
  // Expand tree to show this book
  let found=null;
  root.each(d=>{if(d.data.name===target.name&&d.data.type==="book")found=d;});
  if(!found)return;
  // Ensure ancestors are expanded
  found.ancestors().forEach(a=>{if(a._children){a.children=a._children;a._children=null;}});
  update(root);
  // After transition, focus
  setTimeout(()=>{
    let node=null;root.each(d=>{if(d.data.name===target.name&&d.data.type==="book")node=d;});
    if(!node)return;
    focusNode(node);openPanel(node.data,node);
    // Pan to node
    svg.transition().duration(500).call(zoom.transform,d3.zoomIdentity.translate(W/2-node.y,H/2-node.x).scale(1));
  },340);
}

