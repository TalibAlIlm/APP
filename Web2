<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Talib al-ʿIlm — Islamic Studies Roadmap</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ── RESET & BASE ────────────────────────────────────── */
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#06050d;--bg2:#0d0b18;--bg3:#13111f;
  --gold:#c9a84c;--gold2:#e8c97a;--gold3:#f5e2a8;
  --muted:#3d3858;--border:#1c1930;--text:#cec8e8;
  --panel-w:292px;
}

body{
  background:var(--bg);
  font-family:'IBM Plex Mono',monospace;
  overflow:hidden;width:100vw;height:100vh;color:var(--text);
}

/* Atmospheric depth */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 45% at 15% 25%,rgba(201,168,76,.04) 0%,transparent 65%),
    radial-gradient(ellipse 45% 55% at 85% 75%,rgba(120,80,200,.04) 0%,transparent 60%),
    radial-gradient(ellipse 30% 30% at 50% 50%,rgba(201,168,76,.02) 0%,transparent 70%);
}

/* ── HEADER ──────────────────────────────────────────── */
#header{
  position:fixed;top:0;left:0;right:0;height:46px;
  background:rgba(6,5,13,.96);
  border-bottom:1px solid var(--border);
  box-shadow:0 1px 24px rgba(0,0,0,.5);
  display:flex;align-items:center;padding:0 14px;gap:12px;
  z-index:200;backdrop-filter:blur(14px);
}
#header h1{
  font-family:'Cinzel',serif;font-size:11px;
  letter-spacing:.2em;color:var(--gold);
  white-space:nowrap;text-transform:uppercase;
  text-shadow:0 0 20px rgba(201,168,76,.35);
}
.hsep{width:1px;height:18px;background:var(--border);flex-shrink:0}
.legend{display:flex;align-items:center;gap:9px;overflow:hidden}
.li{display:flex;align-items:center;gap:4px;font-size:8.5px;letter-spacing:.04em;color:var(--muted);white-space:nowrap}
.ld{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.hbtn{margin-left:auto;display:flex;gap:5px;flex-shrink:0}
.hbtn button{
  background:transparent;border:1px solid var(--border);
  color:var(--muted);font-family:'IBM Plex Mono',monospace;
  font-size:9px;letter-spacing:.08em;padding:4px 9px;
  cursor:pointer;text-transform:uppercase;
  transition:all .2s ease;white-space:nowrap;
}
.hbtn button:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.07)}
.hbtn button.active{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.1);
  box-shadow:0 0 10px rgba(201,168,76,.15)}

/* ── CANVAS ──────────────────────────────────────────── */
#canvas{width:100%;height:100%;cursor:grab;display:block;position:relative;z-index:1}
#canvas:active{cursor:grabbing}

/* ── BREADCRUMB ──────────────────────────────────────── */
#breadcrumb{
  position:fixed;top:58px;left:16px;
  font-size:9px;letter-spacing:.1em;color:var(--muted);
  z-index:150;pointer-events:none;text-transform:uppercase;
  opacity:0;transition:opacity .4s ease;
  max-width:55vw;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
#breadcrumb.show{opacity:1}
#breadcrumb span{color:var(--gold2);text-shadow:0 0 8px rgba(232,201,122,.4)}

/* ── PANEL ───────────────────────────────────────────── */
#panel{
  position:fixed;right:calc(-1 * var(--panel-w));top:46px;bottom:0;
  width:var(--panel-w);
  background:rgba(13,11,24,.97);
  border-left:1px solid var(--border);
  box-shadow:-8px 0 32px rgba(0,0,0,.5);
  z-index:300;display:flex;flex-direction:column;
  transition:right .32s cubic-bezier(.34,1.26,.64,1);
  overflow-y:auto;backdrop-filter:blur(20px);
}
#panel.open{right:0}
#panel::-webkit-scrollbar{width:2px}
#panel::-webkit-scrollbar-thumb{background:var(--border)}

#panel-close{
  position:sticky;top:0;right:0;
  align-self:flex-end;margin:10px 10px -4px auto;
  background:none;border:none;color:var(--muted);
  font-size:15px;cursor:pointer;line-height:1;
  transition:color .2s;z-index:1;
}
#panel-close:hover{color:var(--gold);text-shadow:0 0 8px rgba(201,168,76,.5)}

#panel-path{
  padding:12px 14px 0;
  font-size:9px;letter-spacing:.1em;color:var(--muted);
  text-transform:uppercase;line-height:1.9;
}
#panel-path span{color:var(--gold2)}
#panel-title{
  padding:10px 14px 12px;
  font-family:'Cinzel',serif;font-size:12px;
  color:var(--gold2);line-height:1.45;
  border-bottom:1px solid var(--border);
  border-top:1px solid var(--border);
  margin-top:8px;
  text-shadow:0 0 16px rgba(232,201,122,.2);
}
#panel-mem{
  padding:10px 14px 2px;
  font-size:9px;letter-spacing:.12em;
  color:#e8c97a;min-height:28px;
  text-shadow:0 0 10px rgba(232,201,122,.6);
}
#panel-btns{padding:12px 14px 16px;display:flex;flex-direction:column;gap:7px}
.pbtn{
  display:flex;align-items:center;gap:10px;
  padding:10px 13px;
  border:1px solid var(--border);
  background:transparent;color:var(--text);
  font-family:'IBM Plex Mono',monospace;
  font-size:10px;letter-spacing:.06em;
  cursor:pointer;text-align:left;
  transition:all .22s ease;
  text-decoration:none;width:100%;
}
.pbtn:hover{
  border-color:var(--gold);color:var(--gold2);
  background:rgba(201,168,76,.06);
  box-shadow:0 0 16px rgba(201,168,76,.12),inset 0 0 8px rgba(201,168,76,.03);
  transform:translateX(2px);
}
.pbtn .icon{font-size:13px;width:18px;text-align:center;flex-shrink:0;opacity:.8}
#panel-note{
  padding:12px 14px 18px;
  font-size:9px;color:var(--muted);line-height:1.7;
  border-top:1px solid var(--border);
  margin-top:auto;
}

/* ── ZOOM CONTROLS ───────────────────────────────────── */
#controls{position:fixed;bottom:14px;right:14px;display:flex;gap:4px;z-index:150}
.cbtn{
  width:28px;height:28px;
  background:rgba(13,11,24,.9);
  border:1px solid var(--border);
  color:var(--muted);font-size:14px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;backdrop-filter:blur(8px);
}
.cbtn:hover{border-color:var(--gold);color:var(--gold);box-shadow:0 0 10px rgba(201,168,76,.2)}

#hint{
  position:fixed;bottom:14px;left:50%;transform:translateX(-50%);
  font-size:9px;letter-spacing:.08em;color:#221f30;
  pointer-events:none;text-transform:uppercase;white-space:nowrap;
  transition:opacity .4s;
}

/* ── LIST VIEW ───────────────────────────────────────── */
#listview{
  position:fixed;top:46px;left:0;right:0;bottom:0;
  overflow-y:auto;background:var(--bg);
  display:none;z-index:50;
}
#listview.show{display:block}
#listview::-webkit-scrollbar{width:3px}
#listview::-webkit-scrollbar-thumb{background:#1c1930}

.lv-level{border-bottom:1px solid var(--border)}

.lv-lhdr{
  padding:13px 14px;
  font-family:'Cinzel',serif;font-size:10.5px;
  letter-spacing:.14em;text-transform:uppercase;
  cursor:pointer;display:flex;align-items:center;
  justify-content:space-between;user-select:none;gap:10px;
  transition:background .2s;
}
.lv-lhdr:hover{background:rgba(255,255,255,.025)}
.lv-lhdr .ct{font-size:10px;transition:transform .28s cubic-bezier(.4,0,.2,1);color:var(--muted);flex-shrink:0}
.lv-lhdr.open .ct{transform:rotate(90deg)}

.lv-lbody{max-height:0;overflow:hidden;transition:max-height .38s cubic-bezier(.4,0,.2,1)}
.lv-lbody.open{max-height:20000px}

.lv-subject{border-top:1px solid rgba(255,255,255,.035)}
.lv-shdr{
  padding:9px 22px;font-size:9px;letter-spacing:.12em;
  text-transform:uppercase;cursor:pointer;
  display:flex;align-items:center;gap:8px;
  user-select:none;transition:background .15s;
}
.lv-shdr:hover{background:rgba(255,255,255,.018)}
.lv-shdr.open .ct{transform:rotate(90deg)}
.lv-shdr .ct{transition:transform .22s cubic-bezier(.4,0,.2,1);color:var(--muted);margin-left:auto;flex-shrink:0}

.lv-sbody{max-height:0;overflow:hidden;transition:max-height .32s cubic-bezier(.4,0,.2,1);padding:0 28px}
.lv-sbody.open{max-height:5000px;padding-bottom:10px}

.lv-book{
  display:flex;align-items:center;
  padding:5px 0;
  border-bottom:1px solid rgba(255,255,255,.022);
  gap:7px;min-height:30px;
}
.lv-book-num{font-size:8px;color:var(--muted);width:14px;flex-shrink:0;text-align:right}

/* Regular book name */
.lv-book-name{
  font-size:9.5px;opacity:.72;flex:1;line-height:1.35;
  cursor:pointer;transition:opacity .15s ease;
}
.lv-book-name:hover{opacity:1}

/* Memorise: golden glow instead of a box */
.lv-book-name.is-mem{
  color:var(--gold2);opacity:1;
  text-shadow:0 0 8px rgba(232,201,122,.55),0 0 20px rgba(201,168,76,.28);
  animation:mem-pulse 3.2s ease-in-out infinite;
}
@keyframes mem-pulse{
  0%,100%{text-shadow:0 0 6px rgba(232,201,122,.45),0 0 16px rgba(201,168,76,.2)}
  50%{text-shadow:0 0 12px rgba(232,201,122,.75),0 0 28px rgba(201,168,76,.4)}
}

.lv-book-actions{display:flex;gap:3px;flex-shrink:0}
.lv-btn{
  width:20px;height:20px;background:transparent;
  border:1px solid var(--border);color:var(--muted);
  font-size:9px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  text-decoration:none;transition:all .18s ease;line-height:1;
}
.lv-btn:hover{
  border-color:var(--gold);color:var(--gold);
  background:rgba(201,168,76,.08);
  box-shadow:0 0 8px rgba(201,168,76,.2);
}

/* ── D3 SVG STYLES ───────────────────────────────────── */
.link{fill:none;stroke-width:.8px}
.node{cursor:pointer}
.node circle{stroke-width:1.5px;transition:r .15s ease}

/* Memorise label — golden glow via SVG filter */
.mem-label{font-weight:500}

@media(max-width:680px){
  .legend{display:none}
  #header h1{font-size:9px;letter-spacing:.1em}
  .hbtn button{font-size:8px;padding:3px 6px}
}

/* Entrance animation */
@keyframes fadeInUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
#header{animation:fadeInUp .5s ease both}
#hint{animation:fadeInUp .8s .3s ease both}
</style>
</head>
<body>

<!-- ── HEADER ─────────────────────────────────────────── -->
<div id="header">
  <h1>Talib al-&#x02BF;Ilm</h1>
  <div class="hsep"></div>
  <div class="legend">
    <div class="li"><div class="ld" style="background:#a8d5e2"></div>Poems</div>
    <div class="li"><div class="ld" style="background:#ef9a9a"></div>Aqeedah</div>
