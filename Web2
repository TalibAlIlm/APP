// ══════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════
let currentView = 'tree';
let selectedBook = null;
let focusedIds = null;
let nodeId = 0;

// ══════════════════════════════════════════════
// D3 TREE
// ══════════════════════════════════════════════
const W = window.innerWidth, H = window.innerHeight;
const svg = d3.select("#canvas").attr("width",W).attr("height",H);
const g = svg.append("g");

const zoom = d3.zoom().scaleExtent([0.08,4]).on("zoom",e => {
  g.attr("transform",e.transform);
  closePanel();
});
svg.call(zoom).on("dblclick.zoom",null);
svg.on("click",()=>{ if(focusedIds){ clearFocus(); closePanel(); }});

const treeFn = d3.tree().nodeSize([20,260]);
let root = d3.hierarchy(TREE);

// Collapse all except root and levels initially
root.descendants().forEach(d=>{
  if(d.depth >= 2){ d._children = d.children; d.children = null; }
});
root.x0 = 0; root.y0 = 0;

function getNodeColor(d){
  if(d.data.type==="root") return "#c9a84c";
  if(d.data.type==="level") return LC[d.data.level]||"#c9a84c";
  if(d.data.type==="subject") return d.data.color||"#888";
  // book — inherit parent subject color
  return (d.parent&&d.parent.data.color)||"#a0a0c0";
}

function getR(d){
  if(d.data.type==="root") return 13;
  if(d.data.type==="level") return 9;
  if(d.data.type==="subject") return 6;
  return 4;
}

function getLabel(d){
  if(d.data.type==="root") return "Talib al-'Ilm";
  if(d.data.type==="level") return d.data.name + (d.data.subtitle?" · "+d.data.subtitle.split(" · ")[0]:"");
  if(d.data.type==="subject"){
    const n = d.children||d._children;
    return d.data.name + (n?` [${n.length}]`:"");
  }
  const nm = d.data.name.length>36?d.data.name.slice(0,34)+"…":d.data.name;
  return (d.data.mem?"★ ":"")+nm;
}

function diag(d){
  return `M${d.source.y},${d.source.x}C${(d.source.y+d.target.y)/2},${d.source.x} ${(d.source.y+d.target.y)/2},${d.target.x} ${d.target.y},${d.target.x}`;
}

function update(src){
  const td = treeFn(root);
  const nodes = td.descendants();
  const links = td.links();

  // links
  const link = g.selectAll(".link").data(links, d=>d.target.id);
  const le = link.enter().insert("path",".node")
    .attr("class","link")
    .attr("d",()=>{const o={x:src.x0||0,y:src.y0||0};return diag({source:o,target:o});})
    .attr("stroke", d=>{
      const t=d.target;
      if(t.data.type==="level") return LC[t.data.level]||"#444";
      if(t.data.type==="book") return (t.parent&&t.parent.data.color)||"#444";
      return (t.data.color||"#444");
    })
    .attr("opacity",0);
  link.merge(le).transition().duration(300)
    .attr("d",diag)
    .attr("stroke", d=>{
      const t=d.target;
      if(t.data.type==="level") return LC[t.data.level]||"#444";
      if(t.data.type==="book") return (t.parent&&t.parent.data.color)||"#444";
      return (t.data.color||"#444");
    })
    .attr("opacity", d => {
      if(!focusedIds) return 0.2;
      return (focusedIds.has(d.source.id)&&focusedIds.has(d.target.id)) ? 0.7 : 0.04;
    });
  link.exit().transition().duration(300)
    .attr("d",()=>{const o={x:src.x,y:src.y};return diag({source:o,target:o});})
    .attr("opacity",0).remove();

  // nodes
  const node = g.selectAll(".node").data(nodes, d=>d.id||(d.id=++nodeId));
  const ne = node.enter().append("g")
    .attr("class","node")
    .attr("transform",()=>`translate(${src.y0||0},${src.x0||0})`)
    .attr("opacity",0)
    .on("click", handleNodeClick);

  ne.append("circle")
    .attr("r", getR)
    .attr("fill", d=>{
      const c=getNodeColor(d);
      if(d.data.type==="book") return c+"18";
      if(d.data.type==="subject") return c+"28";
      return c+"3a";
    })
    .attr("stroke", getNodeColor)
    .attr("stroke-width", d=>d.data.type==="root"?2:1.5);

  // collapse dot
  ne.append("circle").attr("class","cdot").attr("r",2).attr("fill",getNodeColor).attr("opacity",0);

  ne.append("text")
    .attr("dy","0.31em")
    .attr("font-size", d=>{
      if(d.data.type==="root") return "12px";
      if(d.data.type==="level") return "10px";
      if(d.data.type==="subject") return "9px";
      return "8.5px";
    })
    .attr("fill", d=>{
      const c=getNodeColor(d);
      if(d.data.type==="root"||d.data.type==="level") return c;
      if(d.data.type==="subject") return c+"cc";
      return d.data.mem?c:c+"99";
    })
    .attr("letter-spacing", d=>d.data.type==="level"?"0.1em":"0.03em")
    .text(getLabel);

  const merged = node.merge(ne);
  merged.transition().duration(300)
    .attr("transform", d=>`translate(${d.y},${d.x})`)
    .attr("opacity", d=>{
      if(!focusedIds) return 1;
      return focusedIds.has(d.id)?1:0.06;
    });

  // update text anchor and collapse dot
  merged.select("text")
    .attr("x", d=>{const r=getR(d);return (d.children||d._children)?-(r+5):(r+5);})
    .attr("text-anchor", d=>(d.children||d._children)?"end":"start");
  merged.select(".cdot")
    .attr("opacity", d=>d._children&&d.data.type!=="book"?.7:0);

  node.exit().transition().duration(300)
    .attr("transform",`translate(${src.y},${src.x})`)
    .attr("opacity",0).remove();

  nodes.forEach(d=>{d.x0=d.x;d.y0=d.y;});
}

function handleNodeClick(event, d){
  event.stopPropagation();
  if(d.data.type==="book"){
    focusNode(d);
    openPanel(d);
    return;
  }
  if(d.children){d._children=d.children;d.children=null;}
  else{d.children=d._children;d._children=null;}
  clearFocus();
  closePanel();
  update(d);
}

function focusNode(d){
  const ancestors = d.ancestors();
  focusedIds = new Set(ancestors.map(a=>a.id));
  focusedIds.add(d.id);
  update(d);
  // breadcrumb
  const bc = document.getElementById("breadcrumb");
  const parts = ancestors.reverse().map((a,i)=>{
    if(a.data.type==="root") return "Root";
    if(a.data.type==="level") return a.data.name;
    if(a.data.type==="subject") return a.data.name;
    return "";
  }).filter(Boolean);
  parts.push(d.data.name.length>30?d.data.name.slice(0,28)+"…":d.data.name);
  bc.innerHTML = parts.map((p,i)=>i===parts.length-1?`<span>${p}</span>`:p).join(" › ");
  bc.classList.add("show");
}

function clearFocus(){
  focusedIds=null;
  document.getElementById("breadcrumb").classList.remove("show");
  g.selectAll(".node").transition().duration(300).attr("opacity",1);
  g.selectAll(".link").transition().duration(300).attr("opacity",0.2);
}

// Panel
function openPanel(d){
  selectedBook=d;
  document.getElementById("panel-title").textContent=d.data.name;
  // path
  const anc=d.ancestors().reverse();
  const pathHtml=anc.map((a,i)=>{
    if(a.data.type==="root") return "Root";
    if(a.data.type==="level") return `<span>${a.data.name}</span>`;
    if(a.data.type==="subject") return `<span>${a.data.name}</span>`;
    return "";
  }).filter(Boolean).join(" › ");
  document.getElementById("panel-path").innerHTML=pathHtml;
  document.getElementById("panel-mem").textContent=d.data.mem?"★ Memorize this text":"";
  document.getElementById("btn-info").href=d.data.info||"#";
  document.getElementById("btn-pdf").href=d.data.pdf||"#";
  document.getElementById("btn-video").href=d.data.video||"#";
  document.getElementById("panel").classList.add("open");
  document.getElementById("hint").style.opacity="0";
}

function closePanel(){
  document.getElementById("panel").classList.remove("open");
  document.getElementById("hint").style.opacity="1";
  if(selectedBook){ clearFocus(); selectedBook=null; }
}

document.addEventListener("keydown",e=>{ if(e.key==="Escape") closePanel(); });

// Controls
function resetZoom(){
  svg.transition().duration(400).call(
    zoom.transform, d3.zoomIdentity.translate(W*.08, H/2).scale(.9)
  );
}

function expandAll(){
  root.descendants().forEach(d=>{
    if(d._children){d.children=d._children;d._children=null;}
  });
  clearFocus(); closePanel(); update(root);
}

function collapseToLevels(){
  root.descendants().forEach(d=>{
    if(d.depth>=2&&d.children){d._children=d.children;d.children=null;}
  });
  clearFocus(); closePanel(); update(root);
}

// Initial render + zoom to fit
update(root);
svg.call(zoom.transform, d3.zoomIdentity.translate(W*.06,H/2).scale(.95));

// ══════════════════════════════════════════════
// VIEW TOGGLE
// ══════════════════════════════════════════════
function setView(v){
  currentView=v;
  document.getElementById("btn-tree").classList.toggle("active",v==="tree");
  document.getElementById("btn-list").classList.toggle("active",v==="list");
  document.getElementById("canvas").style.display=v==="tree"?"block":"none";
  document.getElementById("listview").classList.toggle("show",v==="list");
  document.getElementById("hint").style.display=v==="tree"?"block":"none";
  if(v==="list"&&!document.getElementById("listview").innerHTML.trim()) buildList();
  if(v==="tree") closePanel();
}

// ══════════════════════════════════════════════
// LIST VIEW
// ══════════════════════════════════════════════
function buildList(){
  const lv=document.getElementById("listview");
  let html="";
  TREE.children.forEach((level,li)=>{
    const lc=LC[level.level]||"#c9a84c";
    html+=`<div class="lv-level">
      <div class="lv-level-hdr" style="color:${lc};border-left:2px solid ${lc}" onclick="toggleLvl(this)">
        <span>${level.name} — ${level.subtitle||""}</span>
        <span class="caret">›</span>
      </div>
      <div class="lv-level-body">`;
    (level.children||[]).forEach((subj,si)=>{
      html+=`<div class="lv-subject">
        <div class="lv-subj-hdr" style="color:${subj.color}88" onclick="toggleSubj(this)">
          <span>${subj.name}</span>
          <span class="caret">›</span>
        </div>
        <div class="lv-subj-body">`;
      (subj.children||[]).forEach((book,bi)=>{
        const bdata=JSON.stringify({name:book.name,mem:book.mem,info:book.info,pdf:book.pdf,video:book.video}).replace(/"/g,"&quot;");
        html+=`<div class="lv-book" onclick="openListPanel(${JSON.stringify(bdata).replace(/"/g,"&quot;")}, '${level.name}', '${subj.name}')">
          <span class="lv-book-name">${book.mem?'<span style="color:#c9a84c">★</span> ':''} ${book.name}</span>
          <span class="lv-book-arrow">›</span>
        </div>`;
      });
      html+=`</div></div>`;
    });
    html+=`</div></div>`;
  });
  lv.innerHTML=html;
}

function toggleLvl(el){
  el.classList.toggle("open");
  el.nextElementSibling.classList.toggle("open");
}
function toggleSubj(el){
  el.classList.toggle("open");
  el.nextElementSibling.classList.toggle("open");
}

function openListPanel(bdataStr, levelName, subjName){
  try{
    const data=JSON.parse(bdataStr);
    document.getElementById("panel-title").textContent=data.name;
    document.getElementById("panel-path").innerHTML=`<span>${levelName}</span> › <span>${subjName}</span>`;
    document.getElementById("panel-mem").textContent=data.mem?"★ Memorize this text":"";
    document.getElementById("btn-info").href=data.info||"#";
    document.getElementById("btn-pdf").href=data.pdf||"#";
    document.getElementById("btn-video").href=data.video||"#";
    document.getElementById("panel").classList.add("open");
  }catch(e){}
}

// Resize
window.addEventListener("resize",()=>{
  const nw=window.innerWidth,nh=window.innerHeight;
  svg.attr("width",nw).attr("height",nh);
});

// Auto-detect mobile
if(window.innerWidth<700) setView("list");
</script>
