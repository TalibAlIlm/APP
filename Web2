    </a>
    <a class="pbtn" id="btn-pdf" href="#" target="_blank">
      <span class="icon">&#128196;</span> Read / Download PDF
    </a>
    <a class="pbtn" id="btn-video" href="#" target="_blank">
      <span class="icon">&#9654;</span> Watch Reading / Lesson
    </a>
  </div>
  <div id="panel-note">Links will be added for each text. Click outside panel or press Esc to close.</div>
</div>

<!-- LIST VIEW (MOBILE) -->
<div id="listview"></div>

<!-- CONTROLS -->
<div id="controls">
  <button class="cbtn" onclick="zoom.scaleBy(svg,1.3)" title="Zoom In">+</button>
